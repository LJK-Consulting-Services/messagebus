# ---- worktree commands -----------------------------------------------------

def _decode_ws_meta(raw):
    try:
        m = json.loads(raw) if raw else None
    except (TypeError, json.JSONDecodeError):
        return None
    if m and all(k in m for k in ("issue", "agent", "path", "branch", "base_commit")):
        return m
    return None


def _ws_meta(r, issue, agent=None, with_key=False):
    keys = []
    if agent:
        keys.append(k_worktree(issue, agent))
    keys.append(k_worktree(issue))
    for key in keys:
        m = _decode_ws_meta(r.get(key))
        if m:
            return (m, key) if with_key else m
    return (None, None) if with_key else None


def _iter_ws_meta_with_keys(r):
    for key in r.scan_iter(match="bus:worktree:issue:*"):
        m = _decode_ws_meta(r.get(key))
        if m:
            yield key, m


def _iter_ws_meta(r):
    """Yield every registered worktree's metadata dict, skipping malformed or
    legacy entries (missing required keys). Shared by ws list and reap."""
    for _, m in _iter_ws_meta_with_keys(r):
        yield m


def ws_create(r, room, agent, issue, base="dev", branch_type="feat",
              allow_stale=False, allow_nested=False):
    """Core of `ws create` / `claim --worktree`. Returns (rc, path_or_None)."""
    if r.get(k_lock(issue)) != agent:
        sys.stderr.write(f"bus ws create: you ({agent}) must hold the claim on #{issue} "
                         f"(run `bus claim --as {agent} --issue {issue}`) first\n")
        return 1, None
    meta = _ws_meta(r, issue)
    if meta:
        if meta["agent"] == agent and os.path.isdir(meta["path"]):
            return 0, meta["path"]  # resume
        if meta["agent"] != agent:
            sys.stderr.write(f"bus ws create: #{issue} worktree belongs to {meta['agent']} at "
                             f"{meta['path']}; resolve (ws remove) before reclaiming\n")
            return 1, None
        # same agent but the dir is gone -> stale metadata, fall through to recreate
    try:
        main = main_repo_dir()
    except RuntimeError as e:
        sys.stderr.write(f"bus ws create: {e}\n")
        return 1, None
    root = worktree_root(main)
    if path_under(root, main) and not allow_nested:
        sys.stderr.write(f"bus ws create: worktree root {root} is inside the repo {main}; "
                         f"use a sibling dir or pass --allow-nested\n")
        return 1, None
    # A leading '-' would be parsed as a git flag (e.g. base='-p' -> `git fetch
    # origin -p` prunes refs). `ident` and check-ref-format both allow it, so
    # reject it explicitly here — never let base/type become an option token.
    if base.startswith("-") or branch_type.startswith("-"):
        sys.stderr.write(f"bus ws create: base/type must not start with '-' (base={base}, type={branch_type})\n")
        return 1, None
    branch = f"{branch_type}/issue-{issue}-{agent}"
    if not valid_git_ref(main, base) or not valid_git_ref(main, branch):
        sys.stderr.write(f"bus ws create: invalid base/branch ref (base={base}, branch={branch})\n")
        return 1, None
    rc, _, err = git(main, "fetch", "origin", base, check=False)
    if rc != 0 and not allow_stale:
        sys.stderr.write(f"bus ws create: `git fetch origin {base}` failed ({err}); refusing to "
                         f"cut from a possibly-stale base. Fix the network or pass --allow-stale.\n")
        return 1, None
    rc, base_commit, _ = git(main, "rev-parse", "--verify", f"origin/{base}", check=False)
    if rc != 0:
        sys.stderr.write(f"bus ws create: base origin/{base} not found\n")
        return 1, None
    rc, _, _ = git(main, "rev-parse", "--verify", f"refs/heads/{branch}", check=False)
    if rc == 0:
        sys.stderr.write(f"bus ws create: branch {branch} already exists (leftover worktree?); "
                         f"remove it first\n")
        return 1, None
    os.makedirs(root, exist_ok=True)
    path = os.path.abspath(os.path.join(root, f"issue-{issue}-{agent}"))
    rc, _, err = git(main, "worktree", "add", path, "-b", branch, f"origin/{base}", check=False)
    if rc != 0:
        sys.stderr.write(f"bus ws create: git worktree add failed: {err}\n")
        return 1, None
    r.set(k_worktree(issue), json.dumps({
        "issue": issue, "agent": agent, "path": path, "branch": branch,
        "base": base, "base_commit": base_commit, "kind": "solo",
        "detached": False, "created_at": now_iso()}))
    announce(r, room, agent, f"created worktree for #{issue} at {path} (branch {branch})",
             topic=f"issue-{issue}")
    return 0, path


def cmd_ws_create(r, args):
    rc, path = ws_create(r, args.room, args.as_agent, args.issue, base=args.base,
                         branch_type=args.type, allow_stale=args.allow_stale,
                         allow_nested=args.allow_nested)
    if rc == 0:
        print(path)
    return rc


