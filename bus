#!/usr/bin/env python3
"""
bus — a tiny, durable message bus for multi-agent coordination.

Backed by Redis Streams (durable log + per-agent cursor), NOT pub/sub.
Pub/sub drops messages when an agent is mid-turn and not subscribed; a
turn-based agent would lose exactly the messages that matter. Streams
persist every message and each agent tracks its own read position, so an
agent that was busy (or dead) for 10 minutes catches up on wake.

Task ordering uses two layers:
  - Redis SET NX  -> atomic claim lock (resolves the claim race)
  - GitHub issue labels -> durable, human-visible state machine

Commands:
  send     publish a message to a room
  poll     read new messages addressed to you (non-blocking); --topic to scope
  wait     block until a message arrives; --topic / --reply-to to scope
  tail     show recent messages without moving your cursor (observability)
  history  dump the full room log
  watch    live-follow every message in a room (read-only observer); --topic to scope
  thread   print the full reply_to thread containing a message id
  inbox    peek unread messages for you (directed or questions); cursor untouched
  prune    trim a room to the newest --keep messages (destructive, guarded)
  join     register presence and set your cursor to "now"
  agents   list agents currently present in a room
  claim    atomically claim a gh issue (Redis lock + status label); --worktree
  release  release a claim you hold
  renew    extend the TTL on a claim you hold (long-running tasks)
  reap     list stale issue locks (holder absent); --release <issue> to free one
  status   transition a gh issue's status label + announce on the bus
  board    table of gh issues + status label + lock holder + presence
  ws       per-agent git worktrees: ws create/path/list/remove (isolated builds)
  init     create the status:* labels in BUS_GH_REPO

A --topic <t> (poll/wait/watch) or --reply-to <id> (wait) filter narrows delivery
to an exact match, but never hides a __SHUTDOWN__ in poll/wait — the kill-switch
must not be defeated by an agent's own scoping.
  doctor   check Redis connectivity and gh auth

Config via env:
  BUS_REDIS_URL   default redis://127.0.0.1:6379/0
  BUS_ROOM        default "main"
"""

import argparse
import json
import os
import re
import secrets
import sys
import time
from datetime import datetime, timezone

try:
    import redis
    from redis.backoff import ExponentialBackoff
    from redis.retry import Retry
except ImportError:
    sys.stderr.write("bus: redis-py not installed. Run: pip install redis\n")
    sys.exit(2)

DEFAULT_URL = os.environ.get("BUS_REDIS_URL", "redis://127.0.0.1:6379/0")
DEFAULT_ROOM = os.environ.get("BUS_ROOM", "main")
PRESENCE_TTL = 90  # seconds; refreshed on every send/poll/wait/join + pen/huddle op
PEN_TAKE_GRACE = 120  # seconds an absent driver has to reappear before a force-take

# ---- key helpers -----------------------------------------------------------

def k_stream(room):   return f"bus:stream:{room}"
def k_cursor(room, a): return f"bus:cursor:{room}:{a}"
def k_presence(room, a): return f"bus:presence:{room}:{a}"
def k_lock(issue):    return f"bus:lock:issue:{issue}"
def k_worktree(issue, agent=None):
    base = f"bus:worktree:issue:{issue}"
    return f"{base}:agent:{agent}" if agent else base
def k_huddle(issue):  return f"bus:huddle:issue:{issue}"
def k_pen(issue):     return f"bus:pen:issue:{issue}"
def k_penchal(issue): return f"bus:penchal:issue:{issue}"
def k_signoff(issue): return f"bus:signoff:issue:{issue}"
def k_block(issue):   return f"bus:block:issue:{issue}"


def now_iso():
    return datetime.now(timezone.utc).isoformat(timespec="seconds")


SOCKET_TIMEOUT = 5     # seconds; client-side read timeout (fail fast on dead Redis)
# A blocking XREAD must block for LESS than SOCKET_TIMEOUT or the client socket
# read itself times out and raises. So blocking reads are issued in chunks and
# re-blocked in a loop; the chunk must stay safely under SOCKET_TIMEOUT.
BLOCK_CHUNK_MS = 1000

RETRY_ATTEMPTS = 3        # per-command retries inside one client (B3)
HEALTH_CHECK_INTERVAL = 30  # seconds idle before redis-py PINGs a pooled connection

# Backoff schedule for rebuilding a client after the server goes away entirely
# (restart). Bounded on purpose: ~30s total, then the caller gives up loudly
# rather than hanging a turn forever on a Redis that is never coming back.
RECONNECT_BACKOFF = (1, 2, 4, 8, 15)

# What "the connection is gone" looks like coming out of redis-py. A killed
# server usually surfaces as ConnectionError, but a half-open socket can time out
# first, and both mean the same thing to us: this client is dead, build a new one.
# These are the redis-py exceptions, NOT the builtins — builtin ConnectionError is
# an OSError and never matches what redis-py raises.
REDIS_GONE = (redis.exceptions.ConnectionError, redis.exceptions.TimeoutError)


def connect(url):
    """Build a Redis client that survives a blip.

    `retry` + `retry_on_error` make redis-py transparently re-dial and re-send a
    command that died on a dropped/timed-out connection, so a transient blip no
    longer takes an agent's whole turn down. `health_check_interval` PINGs a
    connection that has sat idle, so a long-lived process discovers a stale
    socket on its own terms instead of on the next real command.

    `socket_timeout` stays at 5s: it is load-bearing for the chunked-block
    invariant above (BLOCK_CHUNK_MS < SOCKET_TIMEOUT). Retries wrap the *chunk*,
    they never lengthen a single blocking read.

    Retrying makes writes at-least-once: if an `xadd` reaches the server but the
    reply is lost, the retry appends a second copy. For a coordination log a rare
    duplicate line is strictly better than a crashed agent, and the one write
    where a duplicate would matter — the `SET NX` claim in cmd_claim — already
    re-reads the holder when `NX` reports it lost, so a re-sent claim self-heals
    into "you already hold this issue".
    """
    r = redis.Redis.from_url(
        url, decode_responses=True, socket_timeout=SOCKET_TIMEOUT,
        retry=Retry(ExponentialBackoff(), RETRY_ATTEMPTS),
        retry_on_error=list(REDIS_GONE),
        health_check_interval=HEALTH_CHECK_INTERVAL,
    )
    r.ping()  # fail fast with a clear error if server is down
    return r


def reconnect(url, sleep=time.sleep, deadline=None):
    """Rebuild a client after the server itself went away (a restart, not a blip
    — redis-py's own retry already covers the blip). Returns a live client, or
    None once the backoff schedule (or the caller's deadline) is exhausted.

    `deadline` is a time.monotonic() instant. A caller that promised a bounded
    call — `bus wait --timeout N` — MUST pass it: without it this would happily
    sleep the whole 30s schedule and blow straight through the caller's budget,
    hanging every agent's turn on a Redis that is never coming back.

    `sleep` is injectable so the retry path is testable without real waits."""
    for delay in RECONNECT_BACKOFF:
        if deadline is not None:
            remaining = deadline - time.monotonic()
            if remaining <= 0:
                return None      # budget spent; the caller's timeout wins
            delay = min(delay, remaining)
        sleep(delay)
        try:
            return connect(url)
        except (redis.exceptions.RedisError, OSError):
            continue  # server still down; keep backing off until the budget runs out
    return None


def touch_presence(r, room, agent):
    if agent:
        r.set(k_presence(room, agent), now_iso(), ex=PRESENCE_TTL)


# ---- gh helpers ------------------------------------------------------------

import subprocess

# Target repo for issue/label commands. Without it, gh uses the cwd's repo,
# but `bus` usually runs from the messagebus dir which is NOT that repo.
GH_REPO = os.environ.get("BUS_GH_REPO", "")

# gh subcommands that do NOT accept -R/--repo. Everything else gets -R, so a
# new repo-aware call fails safe (targeted at BUS_GH_REPO) instead of silently
# acting on the cwd's repo.
_NON_REPO = {"auth", "config", "api"}


def gh(args, check=True):
    """Run a gh command, return (rc, stdout, stderr)."""
    full = ["gh"] + args
    if GH_REPO and args and args[0] not in _NON_REPO:
        full += ["-R", GH_REPO]
    p = subprocess.run(full, capture_output=True, text=True)
    if check and p.returncode != 0:
        raise RuntimeError(f"gh {' '.join(args)} failed: {p.stderr.strip()}")
    return p.returncode, p.stdout.strip(), p.stderr.strip()


def issue_labels(issue):
    """Current label names on an issue, or None if gh couldn't answer.

    None (read failed) is deliberately distinct from [] (issue genuinely has no
    labels) so callers don't mistake a transient gh error for 'no labels'.
    """
    rc, out, _ = gh(["issue", "view", str(issue), "--json", "labels",
                     "-q", ".labels[].name"], check=False)
    if rc != 0:
        return None
    return out.splitlines() if out else []


STATUS_LABELS = [
    "status:open", "status:claimed", "status:pr-open",
    "status:merged", "status:deployed", "status:verified",
]


def set_status_label(issue, new_label):
    """Add new_label, remove any other status:* label the issue actually has.

    Deriving the remove-set from the issue's current labels (not blindly
    removing all five) means gh never sees a "remove a label it doesn't have"
    error, so there's no fragile stderr parsing or retry.
    """
    if new_label not in STATUS_LABELS:
        raise ValueError(f"unknown status label: {new_label}")
    current = issue_labels(issue)
    if current is None:
        # couldn't read labels -> add the new one only, don't guess removals.
        # A later transition (with a working read) derives removals from real
        # state and cleans up any stale label, so this self-heals.
        sys.stderr.write(f"warning: could not read labels on #{issue}; "
                         f"adding {new_label} without removing others\n")
        current = []
    remove = [l for l in STATUS_LABELS if l != new_label and l in current]
    args = ["issue", "edit", str(issue), "--add-label", new_label]
    for l in remove:
        args += ["--remove-label", l]
    gh(args, check=False)


# ---- git worktree helpers --------------------------------------------------

def git(repo, *args, check=True):
    """Run a git command in `repo` (argv, never a shell). Returns (rc, out, err)."""
    p = subprocess.run(["git", "-C", repo, *args], capture_output=True, text=True)
    if check and p.returncode != 0:
        raise RuntimeError(f"git {' '.join(args)}: {p.stderr.strip()}")
    return p.returncode, p.stdout.strip(), p.stderr.strip()


def main_repo_dir():
    """Absolute path of the MAIN repo, even when cwd is inside a worktree.

    `--show-toplevel` returns the worktree root, so rooting the sibling worktree
    dir off that would nest worktrees-of-worktrees. `--git-common-dir` points at
    the shared `.git`, whose parent is the main working tree.
    """
    base = os.environ.get("BUS_REPO_DIR") or os.getcwd()
    rc, common, _ = git(base, "rev-parse", "--path-format=absolute",
                        "--git-common-dir", check=False)
    if rc != 0:
        raise RuntimeError("not inside a git repository (set BUS_REPO_DIR)")
    return os.path.dirname(os.path.normpath(common))


def worktree_root(main):
    """Where per-agent worktrees live. Default: sibling `../<repo>-worktrees/`
    (avoids in-repo nesting + the macOS sandbox EPERM seen on hidden dirs). A
    custom BUS_WORKTREE_ROOT inside the repo is rejected unless --allow-nested."""
    env = os.environ.get("BUS_WORKTREE_ROOT")
    if env:
        return os.path.abspath(env)
    return os.path.join(os.path.dirname(main), f"{os.path.basename(main)}-worktrees")


def valid_git_ref(main, ref):
    rc, _, _ = git(main, "check-ref-format", f"refs/heads/{ref}", check=False)
    return rc == 0


def worktree_dirty(path):
    """True if the worktree has uncommitted changes (incl. untracked)."""
    rc, out, _ = git(path, "status", "--porcelain", check=False)
    return rc == 0 and bool(out.strip())


def worktree_unpushed(path, base_commit):
    """True if the branch has commits beyond base_commit that NO remote ref
    contains. A never-pushed branch has no upstream, so an `@{u}` comparison
    would error or report 'nothing' and wrongly call it safe — instead we
    check remote-containment directly, so unpushed work is never silently lost.
    """
    if not base_commit:
        return True  # unknown base -> can't prove pushed -> fail closed
    rc, ahead, _ = git(path, "rev-list", "HEAD", f"^{base_commit}", check=False)
    if rc != 0:
        return True  # can't compute -> assume unpushed (fail closed; git won't
        #              backstop "unpushed" the way it does a dirty tree)
    if not ahead.strip():
        return False  # no commits beyond base -> nothing to lose
    rc, head, _ = git(path, "rev-parse", "HEAD", check=False)
    if rc != 0:
        return True
    rc, contained, _ = git(path, "for-each-ref", "--contains", head,
                          "refs/remotes/", check=False)
    if rc != 0:
        return True
    return not contained.strip()  # commits beyond base AND on no remote = unpushed


def path_under(child, parent):
    """True if `child` is `parent` or nested within it (both absolutised)."""
    child = os.path.abspath(child)
    parent = os.path.abspath(parent)
    return child == parent or child.startswith(parent + os.sep)


# ---- message plumbing ------------------------------------------------------

SHUTDOWN = "__SHUTDOWN__"  # a message with this exact body means "stop"

# exit codes shared with the shell drivers (stop-hook.sh, agent-loop.sh)
RC_DELIVERED = 0   # messages for the agent were printed
RC_NONE = 10       # nothing addressed to the agent (empty poll / wait timeout)
RC_SHUTDOWN = 11   # a delivered message was the shutdown sentinel
RC_REDIS_DOWN = 3  # Redis unreachable (at startup, or a restart we couldn't ride out)


# Version of the on-stream MESSAGE envelope (write side = make_fields, read side
# = fields_to_msg). Bump ONLY on a breaking envelope change; readers tolerate a
# missing field (legacy messages predate the stamp) by defaulting to 0. Distinct
# from EVENT_SCHEMA_VERSION (#81), which versions the kind='event' body — the two
# compose. See CHANGELOG.md.
MESSAGE_SCHEMA_VERSION = 1


def make_fields(frm, to, body, kind="msg", topic="", reply_to=""):
    """The single source of truth for the on-stream message schema (write side,
    mirror of fields_to_msg on the read side)."""
    return {"from": frm, "to": to, "topic": topic,
            "reply_to": reply_to, "kind": kind, "body": body,
            "schema_version": MESSAGE_SCHEMA_VERSION}


# ---- structured observability (B6, #81) ------------------------------------
# A machine-readable event layer that rides the existing room stream alongside
# the human announce() line. An event is a kind='event' message whose body is a
# compact JSON envelope. EVENT_SCHEMA_VERSION versions THIS envelope and is
# deliberately independent of the message-envelope schema_version (#80) — the
# two compose. Events ride the room stream as kind='event' messages the same way
# announce() emits kind='system'; `bus events` is the structured, queryable view.
EVENT_SCHEMA_VERSION = 1

# Stable event type names — the only values allowed in the envelope's "event"
# field. Add a new type here (and its emit site) when a reliability fix wants to
# surface a structured signal. Only EV_DONEGATE_BLOCK is wired on `dev` today.
EV_DONEGATE_BLOCK = "donegate_block"
EV_RECONNECT = "reconnect"                    # B3: agent survived a Redis restart
EV_RETENTION_BLOCKED = "retention_blocked"    # B3: trim refused, unread would drop
EV_RETENTION_FORCED = "retention_forced"      # B3: --force dropped unread messages
EV_DRAIN = "drain"                            # B3: agent handed back state on exit
# B3 note: B6 (#81) also pencilled in an EV_PERSISTENCE_MODE event. Deliberately
#   NOT added: persistence is a property of the server, not of anything that
#   happens on the bus, so there is no event-shaped moment to emit it at — a
#   periodic emitter would just be a metric pretending to be an event. `bus
#   doctor` reports the mode instead (see redis_persistence).
# B6-TODO(#81): B2 (#82) adds EV_LEASE_REJECT + EV_POSTPUSH_MISMATCH here and
#   emits them from _leased_push on force-with-lease rejection / ls-remote drift.
# B6-TODO(#81): B4 adds EV_SELFCONTINUE_BUDGET_EXHAUSTED.
EVENT_TYPES = {EV_DONEGATE_BLOCK, EV_RECONNECT, EV_RETENTION_BLOCKED,
               EV_RETENTION_FORCED, EV_DRAIN}

# Identity stamped on events emitted by operator/system commands that have no
# --as agent of their own (retention). Not an agent id: nothing polls as "bus".
SYSTEM_AGENT = "bus"

_EVENT_VALUE_MAX = 200
# Anything URL/URI-shaped is treated as potentially sensitive (tokens ride in
# query strings, presigned URLs, etc.) and dropped — events carry only scalars.
_EVENT_REDACT_RE = re.compile(r"://")
_EVENT_REDACTED = "<redacted>"


def redact_event_fields(fields):
    """Backstop for the event payload: events are meant to carry only
    non-sensitive scalars (agent ids, issue numbers, short shas, counts,
    booleans). Callers should pass an allowlisted dict; this coerces each value
    to a safe scalar and replaces anything non-scalar, over-long, or URL-shaped
    with '<redacted>' so a careless caller can't leak a secret/URL/token or dump
    a raw exception onto the bus."""
    safe = {}
    for k, v in fields.items():
        if v is None or isinstance(v, int):  # bool is an int subclass
            safe[k] = v
        elif isinstance(v, str):
            safe[k] = _EVENT_REDACTED if (
                len(v) > _EVENT_VALUE_MAX or _EVENT_REDACT_RE.search(v)) else v
        else:
            safe[k] = _EVENT_REDACTED
    return safe


def announce_event(r, room, frm, event, fields, topic=""):
    """Emit a structured event onto the room stream. `event` must be a known
    EVENT_TYPES member; `fields` is an allowlisted scalar map (passed through
    redact_event_fields as defence-in-depth). The event lives in a kind='event'
    message body as a JSON envelope — it broadcasts like a kind='system'
    announce() (so it shows in poll/tail) and `bus events` is the structured,
    type-filterable view of the same records."""
    if event not in EVENT_TYPES:
        raise ValueError(f"unknown event type {event!r}")
    payload = {"schema_version": EVENT_SCHEMA_VERSION, "event": event,
               "fields": redact_event_fields(fields)}
    r.xadd(k_stream(room),
           make_fields(frm, "all", json.dumps(payload, ensure_ascii=False),
                       kind="event", topic=topic))


def parse_event(msg):
    """Decode a kind='event' message body into its event envelope dict, or None
    if the message isn't a well-formed event (wrong kind / bad JSON / missing
    the required "event" field)."""
    if msg.get("kind") != "event":
        return None
    try:
        payload = json.loads(msg["body"])
    except (ValueError, TypeError):
        return None
    if not isinstance(payload, dict) or "event" not in payload:
        return None
    return payload


def read_result_code(delivered):
    if not delivered:
        return RC_NONE
    if any(m["body"].strip() == SHUTDOWN for m in delivered):
        return RC_SHUTDOWN
    return RC_DELIVERED


def terminal_text(value):
    """Escape terminal control characters in untrusted display text."""
    out = []
    for ch in str(value):
        code = ord(ch)
        if ch in "\n\t" or (code >= 32 and code != 127 and not 0x80 <= code <= 0x9F):
            out.append(ch)
        else:
            out.append(f"\\x{code:02x}")
    return "".join(out)


def terminal_line(value):
    return terminal_text(value).replace("\n", " ")


def emit(msg, as_json):
    if as_json:
        print(json.dumps(msg, ensure_ascii=False))
    else:
        who = terminal_line(msg["from"])
        to = terminal_line(msg.get("to", "all"))
        arrow = "" if to == "all" else f" -> {to}"
        topic = f" [{terminal_line(msg['topic'])}]" if msg.get("topic") else ""
        reply = f" (re {terminal_line(msg['reply_to'])})" if msg.get("reply_to") else ""
        print(f"{terminal_line(msg['id'])}  {who}{arrow}{topic}{reply}\n  {terminal_text(msg['body'])}")


def fields_to_msg(msg_id, fields):
    return {
        "id": msg_id,
        "from": fields.get("from", "?"),
        "to": fields.get("to", "all"),
        "topic": fields.get("topic", ""),
        "reply_to": fields.get("reply_to", ""),
        "kind": fields.get("kind", "msg"),
        "body": fields.get("body", ""),
        # Legacy messages predate the stamp → treat a missing field as version 0.
        "schema_version": int(fields.get("schema_version", 0)),
    }


def deliverable(msg, agent, topic=None, reply_to=None):
    """True if this message should be shown to `agent`.

    `topic` / `reply_to`, if given, narrow delivery (exact match) — but NEITHER
    filters the shutdown signal. A scoped listener (one topic, or awaiting one
    reply) must never let its own scoping swallow a `--to all __SHUTDOWN__`
    kill-switch, so __SHUTDOWN__ always passes both filters.
    """
    addressed = msg["to"] == "all" or msg["to"] == agent
    if not addressed:
        return False
    is_shutdown = msg["body"].strip() == SHUTDOWN
    if msg["from"] == agent and not is_shutdown:
        return False  # suppress self-echo, except a self-addressed shutdown
    if is_shutdown:
        return True   # stop signal bypasses every narrowing filter
    if topic and msg["topic"] != topic:
        return False  # topic narrows chatter, never the stop signal
    if reply_to and msg["reply_to"] != reply_to:
        return False  # awaiting a specific reply, never the stop signal
    return True


# ---- commands --------------------------------------------------------------

def cmd_send(r, args):
    body = args.body
    if body == "-" or (body is None and not sys.stdin.isatty()):
        body = sys.stdin.read()
    if not body:
        sys.stderr.write("bus send: empty body\n")
        return 2
    fields = make_fields(args.frm, args.to, body.strip(),
                         kind=args.kind, topic=args.topic or "",
                         reply_to=args.reply_to or "")
    msg_id = r.xadd(k_stream(args.room), fields)
    touch_presence(r, args.room, args.frm)
    if args.json:
        print(json.dumps({"id": msg_id, "room": args.room}))
    else:
        print(f"sent {msg_id} to room={args.room} to={args.to}")
    return 0


def read_from_cursor(r, room, agent, block_ms=None, count=100, topic=None, reply_to=None):
    """One XREAD from the agent's cursor. Returns (delivered, last_seen_id).

    The cursor advances past EVERY entry seen (last_seen), so a topic filter
    only narrows what's delivered — non-matching messages are consumed, not
    re-read on the next poll.
    """
    cur = r.get(k_cursor(room, agent)) or "0-0"
    kwargs = {"count": count}
    if block_ms is not None:
        kwargs["block"] = block_ms
    resp = r.xread({k_stream(room): cur}, **kwargs)
    delivered, last_seen = [], None
    if resp:
        _, entries = resp[0]
        for msg_id, fields in entries:
            last_seen = msg_id
            msg = fields_to_msg(msg_id, fields)
            if deliverable(msg, agent, topic, reply_to):
                delivered.append(msg)
    return delivered, last_seen


def cmd_poll(r, args):
    touch_presence(r, args.room, args.as_agent)
    delivered, last_seen = read_from_cursor(
        r, args.room, args.as_agent, topic=args.topic)
    if last_seen:
        r.set(k_cursor(args.room, args.as_agent), last_seen)
    for m in delivered:
        emit(m, args.json)
    if not delivered and not args.json:
        print("(no new messages)")
    return read_result_code(delivered)


def cmd_wait(r, args):
    """Block up to --timeout seconds for a message addressed to us.

    We advance the cursor past every message we see (even ones not for us),
    then keep blocking on the remaining time budget so unrelated traffic
    doesn't make us return empty.

    Survives a Redis restart: a dropped connection rebuilds the client and
    re-blocks from the SAME cursor (which lives in Redis, so it is exactly where
    we left off, and AOF carries it across the restart). Reconnect time is charged
    against the caller's budget AND capped by it, so `--timeout` still bounds the
    call even when Redis never comes back.
    """
    touch_presence(r, args.room, args.as_agent)
    deadline = time.monotonic() + args.timeout

    def revive():
        """Rebuild the client after the server went away. Returns False when it
        is not coming back inside our budget."""
        nonlocal r
        fresh = reconnect(args.url, deadline=deadline)
        if fresh is None:
            sys.stderr.write("bus wait: lost Redis and could not reconnect\n")
            return False
        r = fresh
        # Presence expired while we were disconnected; re-register, then say so on
        # the stream. Both are writes, so they can only run AFTER the reconnect
        # succeeded — never announce a reconnect to a dead Redis.
        touch_presence(r, args.room, args.as_agent)
        announce_event(r, args.room, args.as_agent, EV_RECONNECT,
                       {"agent": args.as_agent, "room": args.room, "cmd": "wait"})
        return True

    while True:
        remaining = deadline - time.monotonic()
        if remaining <= 0:
            if not args.json:
                print("(timeout, no messages)")
            return RC_NONE
        # Block in chunks under SOCKET_TIMEOUT (a longer single block would trip
        # the client socket read timeout and crash). Floor at 1ms; XREAD BLOCK 0
        # would block forever. The outer loop re-blocks on the remaining budget.
        block_ms = max(1, min(BLOCK_CHUNK_MS, int(remaining * 1000)))
        try:
            delivered, last_seen = read_from_cursor(
                r, args.room, args.as_agent, block_ms=block_ms,
                topic=args.topic, reply_to=args.reply_to
            )
        except REDIS_GONE:
            if not revive():
                return RC_REDIS_DOWN
            continue  # nothing was read; re-block from the same (unmoved) cursor
        # The messages are in hand. Advancing the cursor is a SEPARATE failure:
        # it must never be able to discard them. If the server dies on this write
        # we still deliver — a message re-read on the next turn is at-least-once
        # (which this bus already is, see connect()), but a swallowed __SHUTDOWN__
        # would be unrecoverable, and that is exactly what dropping `delivered`
        # here would do.
        if last_seen:
            try:
                r.set(k_cursor(args.room, args.as_agent), last_seen)
            except REDIS_GONE:
                if not delivered:
                    if not revive():
                        return RC_REDIS_DOWN
                    continue
                # else: fall through and deliver what we already read.
        if delivered:
            for m in delivered:
                emit(m, args.json)
            return read_result_code(delivered)
        # saw only traffic not addressed to us (or nothing) -> keep waiting


TOPIC_SCAN_CAP = 1000  # how far `watch --topic` scans back for context matches


def emit_recent(r, room, n, as_json, topic=None):
    """Print up to the last n messages (oldest-first) and return the newest
    message id in the stream (for follow continuation), or None if empty.

    With `topic`, print the last n messages *matching* that topic — scanning
    back a bounded window so a filtered follow shows real matches, not "last n
    raw then filtered to maybe zero" (per the ratified spec). Still returns the
    newest RAW id so the caller's follow cursor advances correctly.
    """
    if not topic:
        entries = r.xrevrange(k_stream(room), count=n)
        for msg_id, fields in reversed(entries):
            emit(fields_to_msg(msg_id, fields), as_json)
        return entries[0][0] if entries else None
    window = r.xrevrange(k_stream(room), count=TOPIC_SCAN_CAP)  # newest-first
    newest = window[0][0] if window else None
    matches = [(mid, f) for mid, f in window if f.get("topic") == topic]
    for msg_id, fields in reversed(matches[:n]):  # the n newest matches, oldest-first
        emit(fields_to_msg(msg_id, fields), as_json)
    return newest


def cmd_tail(r, args):
    emit_recent(r, args.room, args.n, args.json)
    return 0


def cmd_history(r, args):
    entries = r.xrange(k_stream(args.room), count=args.n)
    for msg_id, fields in entries:
        emit(fields_to_msg(msg_id, fields), args.json)
    return 0


EVENT_SCAN_CAP = 2000  # how far `bus events` scans back to find matching events


def cmd_events(r, args):
    """List recent structured events (kind='event') on the room stream, oldest
    -first, optionally filtered to a single --type. Human table by default; one
    JSON object per line with --json. Scans back a bounded window so a filtered
    view shows real matches, not "last n raw then filtered to maybe zero"."""
    if args.type and args.type not in EVENT_TYPES:
        sys.stderr.write(f"bus events: unknown --type {args.type!r}; "
                         f"known: {', '.join(sorted(EVENT_TYPES))}\n")
        return 1
    window = r.xrevrange(k_stream(args.room), count=EVENT_SCAN_CAP)  # newest-first
    rows = []
    for mid, fields in window:
        if fields.get("kind") != "event":  # cheap skip before building the msg dict
            continue
        msg = fields_to_msg(mid, fields)
        payload = parse_event(msg)
        if payload is None:
            continue
        if args.type and payload.get("event") != args.type:
            continue
        rows.append((mid, msg, payload))
        if len(rows) >= args.n:
            break
    for mid, msg, payload in reversed(rows):  # oldest-first
        if args.json:
            # Explicit stream fields last so the authoritative id/from/topic win
            # over any id/from/topic a raw event body might carry.
            print(json.dumps({**payload, "id": mid, "from": msg["from"],
                              "topic": msg["topic"]}, ensure_ascii=False))
        else:
            flat = " ".join(f"{terminal_line(k)}={terminal_line(v)}"
                            for k, v in payload.get("fields", {}).items())
            print(f"{terminal_line(mid)}  {terminal_line(msg['from'])}  "
                  f"{terminal_line(payload.get('event', '?'))}"
                  f"{'  ' + flat if flat else ''}")
    return 0


def _id_key(sid):
    """Sort key for a Redis stream id 'ms-seq' (numeric, not lexicographic —
    '9-0' must sort before '10-0')."""
    ms, _, seq = sid.partition("-")
    return (int(ms), int(seq or 0))


def cmd_thread(r, args):
    """Print the full reply_to thread containing message <id>: walk up to the
    root, then print every message reachable down the reply_to tree, in order."""
    byid = {mid: fields_to_msg(mid, f)
            for mid, f in r.xrange(k_stream(args.room))}
    if args.id not in byid:
        sys.stderr.write(f"bus thread: message {args.id} not in room {args.room}\n")
        return 1
    children = {}
    for mid, m in byid.items():
        rt = m["reply_to"]
        if rt and rt in byid:
            children.setdefault(rt, []).append(mid)
    root, seen = args.id, set()          # walk up to the thread root
    while byid[root]["reply_to"] in byid and root not in seen:
        seen.add(root)
        root = byid[root]["reply_to"]
    thread, stack = set(), [root]        # collect the whole subtree from root
    while stack:
        x = stack.pop()
        if x in thread:
            continue
        thread.add(x)
        stack.extend(children.get(x, []))
    for mid in sorted(thread, key=_id_key):
        emit(byid[mid], args.json)
    return 0


def cmd_inbox(r, args):
    """PEEK (does NOT advance the cursor) the unread messages that need your
    attention: directed to you, or questions. Cursor is left untouched so a
    later poll/wait still delivers them."""
    touch_presence(r, args.room, args.as_agent)
    cur = r.get(k_cursor(args.room, args.as_agent)) or "0-0"
    peek_cap = 1000
    resp = r.xread({k_stream(args.room): cur}, count=peek_cap)  # bounded peek, no block
    entries = resp[0][1] if resp else []
    items = []
    for mid, f in entries:
        m = fields_to_msg(mid, f)
        if m["from"] == args.as_agent:
            continue
        directed = m["to"] == args.as_agent
        # a question counts only if it's actually addressed to me (or broadcast);
        # a question aimed at another agent is not my inbox.
        if directed or (m["kind"] == "question" and m["to"] == "all"):
            items.append(m)
    if len(entries) == peek_cap:
        sys.stderr.write(f"bus inbox: showing the oldest {peek_cap} unread; more remain — poll to advance\n")
    if args.json:
        for m in items:
            emit(m, True)  # JSONL, consistent with poll/wait/tail/history
    elif not items:
        print("(inbox empty — no unread directed messages or questions)")
    else:
        for m in items:
            tag = "Q" if m["kind"] == "question" else "@"
            topic = f" [{terminal_line(m['topic'])}]" if m["topic"] else ""
            body = terminal_line(m["body"])[:100]
            print(f"{tag} {terminal_line(m['id'])}  {terminal_line(m['from'])}{topic}: {body}")
    return 0


def xtrim_minid(r, stream, minid):
    return r.execute_command("XTRIM", stream, "MINID", minid)


def cursor_has_unread_before(r, stream, cursor, boundary):
    return bool(r.xrange(stream, f"({cursor}", f"({boundary}", count=1))


def safe_trim_room(r, room, keep, force=False, dry_run=False):
    """Cursor-aware retention for ONE room. The single trim path — `bus prune`
    and any scheduled retention job both go through here, so neither can invent
    its own (unsafe) bound.

    Returns a result dict: {room, keep, total, boundary, behind, blocked,
    trimmed, removed, remaining}, where `behind` is [{agent, cursor}] for every
    agent whose cursor still has unread messages below the keep-window boundary,
    and `blocked` means the trim was refused to protect them.

    Why never `XADD MAXLEN` / `XTRIM MAXLEN`: a maxlen trim drops the oldest N
    entries by count, with no idea where anyone's cursor is — it silently deletes
    messages a lagging agent has not read. This trims by MINID at a boundary
    already checked against every cursor. If a writer appends between the scan
    and the trim, MINID may keep MORE than `keep`, but it can never move the
    deletion boundary forward onto unread messages we did not check.

    Emitting the retention events lives HERE, with the trim, not in `cmd_prune`:
    the whole point of the seam is that a second caller (a scheduled retention
    job) cannot trim — or refuse to trim — without leaving the same audit trail.

    `dry_run` computes the identical decision and reports it, writing nothing at
    all: no trim, and no event either.
    """
    stream = k_stream(room)
    total = r.xlen(stream)
    result = {"room": room, "keep": keep, "total": total, "boundary": None,
              "behind": [], "blocked": False, "trimmed": False,
              "removed": 0, "remaining": total}
    if total <= keep:
        return result
    boundary = r.xrevrange(stream, count=keep)[-1][0]  # oldest id we'd keep
    result["boundary"] = boundary
    for key in r.scan_iter(match=k_cursor(room, "*")):
        cval = r.get(key)
        if cval and cursor_has_unread_before(r, stream, cval, boundary):
            result["behind"].append({"agent": key.rsplit(":", 1)[-1], "cursor": cval})
    result["behind"].sort(key=lambda b: b["agent"])
    behind = result["behind"]
    result["blocked"] = bool(behind) and not force
    if dry_run:
        return result
    # Payloads are counts and ids only — an agent id is charset-checked (`ident`)
    # and a cursor/boundary is a stream id, so neither can smuggle free text onto
    # the stream.
    if result["blocked"]:
        announce_event(r, room, SYSTEM_AGENT, EV_RETENTION_BLOCKED,
                       {"room": room, "keep": keep, "total": total,
                        "boundary": boundary, "behind": len(behind)})
        return result
    result["removed"] = xtrim_minid(r, stream, boundary)
    result["remaining"] = r.xlen(stream)
    result["trimmed"] = True
    if behind:  # --force: we dropped messages someone had not read
        # Emitted AFTER the trim, or the trim would delete the very event that
        # records it.
        announce_event(r, room, SYSTEM_AGENT, EV_RETENTION_FORCED,
                       {"room": room, "keep": keep, "removed": result["removed"],
                        "boundary": boundary, "behind": len(behind)})
    return result


def cmd_prune(r, args):
    """Trim a room's stream to the newest --keep messages. DESTRUCTIVE. Refuses
    if any agent's cursor is behind the keep-window (would drop unread), unless
    --force. Never auto-runs; operator-invoked only. Presentation only — the
    retention decision, the trim and its events all belong to safe_trim_room."""
    res = safe_trim_room(r, args.room, args.keep, force=args.force,
                         dry_run=args.dry_run)
    behind = res["behind"]
    if args.json:
        print(json.dumps({**res, "dry_run": args.dry_run}))
    elif res["boundary"] is None:
        print(f"room {args.room}: {res['total']} messages <= keep {args.keep}; nothing to trim")
    elif res["blocked"]:
        who = ", ".join(f"{terminal_line(b['agent'])}@{terminal_line(b['cursor'])}"
                        for b in behind)
        sys.stderr.write(
            f"bus prune: REFUSING — {len(behind)} agent cursor(s) behind the keep-window "
            f"boundary {terminal_line(res['boundary'])}; trimming would drop unread messages ({who}). "
            f"Re-run with --force to override.\n")
    elif args.dry_run:
        print(f"room {args.room}: would trim below {res['boundary']} "
              f"(total {res['total']}, keep {args.keep}); no cursor is behind")
    else:
        print(f"pruned room {args.room}: removed {res['removed']}, "
              f"kept {res['remaining']} (was {res['total']})")
        if behind:
            sys.stderr.write(f"bus prune: --force: dropped unread for "
                             f"{len(behind)} lagging agent(s)\n")
    return 1 if res["blocked"] else 0


def _is_huddle_lock(holder):
    """A huddle session lock (holder `huddle:issue-N`, see huddle_holder) is held
    by the shared co-work session, not by any single agent — it has no presence
    key, so presence-based staleness never applies. Treat it as a live session."""
    return bool(holder) and holder.startswith("huddle:")


def _holder_present(r, holder):
    """True if `holder` has a presence key in ANY room (locks are global, an
    agent may be live in a different room than the one reap was invoked for)."""
    return bool(holder) and any(True for _ in r.scan_iter(match=f"bus:presence:*:{holder}"))


def stale_lock_info(r, issue, present_set=None):
    """Return (holder, ttl) if the lock is held by an absent agent, else None.
    Pass `present_set` (a snapshot of present agent ids) to avoid a per-call
    keyspace scan when checking many locks; omit it for a single fresh check."""
    holder = r.get(k_lock(issue))
    if not holder:
        return None
    if _is_huddle_lock(holder):
        return None  # a live huddle session, never a dead-agent lock
    present = holder in present_set if present_set is not None else _holder_present(r, holder)
    if present:
        return None
    return holder, r.ttl(k_lock(issue))


def compare_delete(r, key, value):
    """Atomically DEL `key`, but only while it still holds `value`. Deleting a
    token someone else now owns is the whole failure mode this prevents."""
    return r.eval(
        """
        if redis.call('GET', KEYS[1]) == ARGV[1] then
            return redis.call('DEL', KEYS[1])
        end
        return 0
        """,
        1, key, value,
    )


def compare_delete_lock(r, issue, holder):
    return compare_delete(r, k_lock(issue), holder)


def compare_set_huddle_meta(r, issue, holder, meta_json, pen_holder=None):
    keys = [k_lock(issue), k_huddle(issue)]
    argv = [holder, meta_json]
    script = """
        if redis.call('GET', KEYS[1]) == ARGV[1] then
            redis.call('SET', KEYS[2], ARGV[2])
            return 1
        end
        return 0
        """
    if pen_holder is not None:
        keys.extend([k_pen(issue), k_penchal(issue)])
        argv.append(pen_holder)
        script = """
        if redis.call('GET', KEYS[1]) == ARGV[1] then
            redis.call('SET', KEYS[2], ARGV[2])
            redis.call('SET', KEYS[3], ARGV[3])
            redis.call('DEL', KEYS[4])
            return 1
        end
        return 0
        """
    return r.eval(
        script,
        len(keys), *keys, *argv,
    )


def cmd_reap(r, args):
    """List issue locks whose holder has no presence anywhere (possibly a dead
    agent). ADVISORY — the 8h lock TTL is the real death-expiry, and a turn-based
    agent idle past its 90s presence TTL is NOT dead. Absent presence is a weak
    death signal, so there is deliberately NO blanket release: `--release <issue>`
    frees exactly ONE lock the operator has verified is genuinely dead."""
    present_set = {k.rsplit(":", 1)[-1] for k in r.scan_iter(match="bus:presence:*")}
    stale = []
    for key in r.scan_iter(match="bus:lock:issue:*"):
        issue = key.rsplit(":", 1)[-1]
        info = stale_lock_info(r, issue, present_set)
        if info:
            holder, ttl = info
            stale.append((issue, holder, ttl))
    stale.sort(key=lambda s: int(s[0]) if s[0].isdigit() else 0)
    if args.json:
        print(json.dumps([{"issue": i, "holder": h, "ttl": t} for i, h, t in stale]))
    elif not stale:
        print("no stale locks (every lock holder is present)")
    else:
        for i, h, t in stale:
            print(f"issue #{terminal_line(i)}\tholder={terminal_line(h)}\tttl={t}s\tpresent=no")
    # advisory: worktrees whose holder is absent (possible dead agent). Never
    # auto-removed — operator verifies the work is captured, then ws remove --force.
    if not args.json:
        orphans = [m for m in _iter_ws_meta(r) if m["agent"] not in present_set]
        if orphans:
            print("orphan worktrees (holder absent — verify work captured, then `ws remove --as <agent> --issue N --force`):")
            for m in sorted(orphans, key=lambda x: int(x["issue"]) if str(x["issue"]).isdigit() else 0):
                kind = m.get("kind", "solo")
                print(f"  #{terminal_line(str(m['issue']))}\t{terminal_line(kind)}\t"
                      f"{terminal_line(m['agent'])}\t{terminal_line(m['path'])}")
    if args.release is not None:
        target = str(args.release)
        current = stale_lock_info(r, target)
        if not current:
            sys.stderr.write(f"bus reap --release {target}: not a stale lock "
                             f"(holder present, or not locked) — refusing to release\n")
            return 1
        holder, _ = current
        if not compare_delete_lock(r, target, holder):
            sys.stderr.write(f"bus reap --release {target}: lock changed while releasing — refusing\n")
            return 1
        print(f"released stale lock on #{target} (was {terminal_line(holder)})")
    return 0


def _issue_sort(issue):
    return int(issue) if str(issue).isdigit() else 0


def _held_by(r, pattern, agent):
    """Issue numbers whose key under `pattern` is currently owned by `agent`.
    One MGET for the whole match, as cmd_agents does — not a GET per key."""
    keys = list(r.scan_iter(match=pattern))
    vals = r.mget(keys) if keys else []  # MGET of an empty list is an error
    held = [k.rsplit(":", 1)[-1] for k, v in zip(keys, vals) if v == agent]
    held.sort(key=_issue_sort)
    return held


def _unpushed_pen_issues(r, agent, issues):
    """Of `issues`, the ones whose registered worktree still holds commits that
    have reached no remote — work the next driver would not inherit."""
    risky = []
    for issue in issues:
        meta = _ws_meta(r, issue, agent)
        # No registered worktree (or it's already gone) means there is no local
        # work to strand. worktree_unpushed fails closed on an unreadable repo,
        # so the isdir check keeps a removed worktree from wedging drain forever.
        if not meta or not os.path.isdir(meta["path"]):
            continue
        if worktree_unpushed(meta["path"], meta["base_commit"]):
            risky.append(issue)
    return risky


def cmd_drain(r, args):
    """Graceful shutdown: hand back the volatile state this agent holds so peers
    aren't left waiting on a process that is leaving.

    Releases the write pen on every huddle this agent drives (CAS, so a pen that
    has already moved on is never stolen) and clears the agent's presence keys.
    A released pen is unheld, and `pen take` grabs an unheld pen immediately, so
    peers resume at once instead of waiting out PEN_TAKE_GRACE. The huddle's
    `driver` metadata is cleared with the pen — leaving it set would make
    `huddle status` name a driver that `pen status` says does not exist.

    Deliberately NOT done:
      * closing the huddle — a unilateral close would drive straight through the
        done-gate while other participants are still live and still signing off;
      * releasing claim locks — a claim is durable work state, mirrored on the gh
        issue; dropping it silently invites a second agent to re-claim
        half-finished work. Held claims are reported, not touched.

    Clearing presence is what lets `bus reap` see this agent's claim locks as
    stale — but note it ALSO drops the agent out of the done-gate's
    present-participant check, so a huddle can then close without its sign-off.
    That is why an EV_DRAIN event is always emitted, even when no pen moved: a
    drain must never be a silent way to disappear from a gate.

    Fail-closed: refuses while a pen we hold has committed-but-unpushed work,
    because the next driver would build on a tip that is missing it.
    """
    agent = args.as_agent
    pens = _held_by(r, "bus:pen:issue:*", agent)
    locks = _held_by(r, "bus:lock:issue:*", agent)
    pen_sessions = {}
    for issue in pens:
        meta = _huddle_meta(r, issue)
        pen_sessions[issue] = huddle_meta_holder(meta, issue) if meta else _NO_HUDDLE_SESSION
    risky = _unpushed_pen_issues(r, agent, pens)
    if risky and not args.force:
        sys.stderr.write(
            f"bus drain: REFUSING — you hold the pen on "
            f"{', '.join('#' + terminal_line(i) for i in risky)} with committed-but-unpushed "
            f"work. Run `bus pen checkpoint --as {agent} --issue <N>` first, or --force to "
            f"drop the pen and strand it.\n")
        return 1
    released = []
    for issue in pens:
        if _release_pen_driver(r, issue, agent, pen_sessions[issue]):
            released.append(issue)
    for issue in released:
        announce(r, args.room, agent,
                 f"draining on shutdown: released the write pen on #{issue} "
                 f"(unheld — any participant may `pen take` it now)",
                 topic=f"issue-{issue}")
        # Scalars only: an issue number and booleans. Nothing free-text.
        announce_event(r, args.room, agent, EV_DRAIN,
                       {"agent": agent, "issue": _issue_sort(issue),
                        "pen_released": True, "unpushed": issue in risky},
                       topic=f"issue-{issue}")
    # A drain with no pen to release still leaves the gate: dropping presence is
    # what removes us from the done-gate's present-participant check. Emit the
    # departure itself so that is never silent (the per-pen events above already
    # cover the pens; this is the one that fires regardless).
    announce_event(r, args.room, agent, EV_DRAIN,
                   {"agent": agent, "pens_released": len(released),
                    "claims_held": len(locks), "presence_cleared": True})
    # Presence last: while we still hold it, the announces above are attributable
    # to a live agent. Agent ids and room names are charset-checked, so neither
    # can smuggle a glob into this match. DEL is variadic and returns the count,
    # so every room clears in one round-trip.
    stale = list(r.scan_iter(match=f"bus:presence:*:{agent}"))
    cleared = r.delete(*stale) if stale else 0
    if args.json:
        print(json.dumps({"agent": agent, "pens_released": released,
                          "presence_cleared": cleared, "claims_held": locks,
                          "unpushed": risky}))
        return 0
    print(f"{agent} drained: released {len(released)} pen(s), cleared {cleared} presence key(s)")
    if locks:
        print("  claims still held (durable — release explicitly, or let `bus reap` see them "
              f"stale now that presence is gone): {', '.join('#' + terminal_line(i) for i in locks)}")
    return 0


def cmd_board(r, args):
    """One table: every status-labelled gh issue + its status + Redis lock
    holder + whether that holder is present. Composes gh + Redis; read-only."""
    if not GH_REPO:
        sys.stderr.write("bus board: set BUS_GH_REPO=owner/repo\n")
        return 2
    rc, out, err = gh(["issue", "list", "--state", "all", "--limit", "1000",
                       "--json", "number,title,labels"], check=False)
    gh_rows = {}
    try:
        issues = json.loads(out) if (rc == 0 and out) else []
    except json.JSONDecodeError:
        issues = []
        rc = 1
    if rc != 0:
        sys.stderr.write(f"bus board: gh issue list unavailable; showing Redis locks only: {err}\n")
    else:
        for it in issues:
            labels = [l["name"] for l in (it.get("labels") or [])]
            status = next((l for l in labels if l.startswith("status:")), None)
            if status:
                gh_rows[str(it["number"])] = {
                    "issue": str(it["number"]),
                    "status": status,
                    "title": it.get("title", ""),  # raw; escaped only for the human table
                }
    lock_rows = {}
    for key in r.scan_iter(match="bus:lock:issue:*"):
        issue = key.rsplit(":", 1)[-1]
        lock_rows[issue] = r.get(key)
    present_set = {k.rsplit(":", 1)[-1] for k in r.scan_iter(match="bus:presence:*")}
    rows = []
    for issue in sorted(set(gh_rows) | set(lock_rows),
                        key=lambda x: int(x) if x.isdigit() else 0):
        holder = lock_rows.get(issue)
        meta = gh_rows.get(issue, {})
        if not holder:
            present = "-"
        elif _is_huddle_lock(holder):
            present = "sesh"  # a shared huddle session, not a single-agent presence
        else:
            present = "yes" if holder in present_set else "no"
        rows.append((issue, meta.get("status", "unknown"), holder or "-",
                     present, meta.get("title", "unknown")))
    # rows are already built in numeric issue order above; a re-sort by the
    # string issue id would put #10 before #2, so don't.
    if args.json:
        print(json.dumps([{"issue": n, "status": s, "holder": h, "present": p, "title": t}
                          for n, s, h, p, t in rows]))
        return 0
    if not rows:
        print("(board empty — no status-labelled or claimed issues)")
        return 0
    print(f"{'ISSUE':<6} {'STATUS':<16} {'HOLDER':<14} {'PRES':<4} TITLE")
    for n, s, h, p, t in rows:
        print(f"#{terminal_line(n):<5} {terminal_line(s):<16} {terminal_line(h):<14} {p:<4} {terminal_line(t)[:44]}")
    return 0


def cmd_watch(r, args):
    """Live-follow messages in a room as they arrive (tail -f style).

    Read-only OBSERVER: it never registers presence or moves any agent's cursor,
    so watching a room doesn't perturb the agents working in it. Shows the last
    -n messages for context, then blocks for new ones until Ctrl-C. With
    --topic, only messages with that topic are shown (context and live).

    Survives a Redis restart by rebuilding the client and re-blocking from the
    same `last` id. That id is local (watch has no persisted cursor), so it MUST
    be carried across the reconnect — resetting to "$" would silently swallow
    every message published while the server was down. Reconnects are reported on
    stderr, never as an EV_RECONNECT event: an observer that wrote to the stream
    would no longer be an observer.
    """
    topic = args.topic
    last = "$"  # "$" = only messages added after we start blocking
    if args.n > 0:
        newest = emit_recent(r, args.room, args.n, args.json, topic=topic)
        if newest:
            last = newest  # continue strictly after the newest RAW message
    if last == "$":
        # Pin "$" to a concrete id before we ever block. "$" is re-resolved by
        # whatever client evaluates it, so carrying it across a reconnect would
        # silently skip everything published during the outage (`-n 0`, or an
        # empty room at start-up, are the ways to get here). An empty stream has
        # no id to pin to — and nothing to miss either, since a server that is
        # down accepts no writes.
        newest_raw = r.xrevrange(k_stream(args.room), count=1)
        if newest_raw:
            last = newest_raw[0][0]
    sys.stdout.flush()
    try:
        while True:
            # block in chunks under SOCKET_TIMEOUT (block=0 would block forever
            # and trip the client socket read timeout); loop on empty returns.
            try:
                resp = r.xread({k_stream(args.room): last}, block=BLOCK_CHUNK_MS)
            except REDIS_GONE:
                r = reconnect(args.url)
                if r is None:
                    sys.stderr.write("bus watch: lost Redis and could not reconnect\n")
                    return RC_REDIS_DOWN
                sys.stderr.write(f"bus watch: reconnected to Redis; resuming after {last}\n")
                continue
            if not resp:
                continue
            _, entries = resp[0]
            for msg_id, fields in entries:
                last = msg_id  # advance past every raw message, matched or not
                if topic and fields.get("topic") != topic:
                    continue   # filter live-follow before emitting
                emit(fields_to_msg(msg_id, fields), args.json)
            # a follow tool must flush per batch or a piped consumer sees nothing
            # until the buffer fills (stdout is block-buffered when not a tty).
            sys.stdout.flush()
    except KeyboardInterrupt:
        return 0


def cmd_join(r, args):
    # start reading from "now": don't replay the whole room on first join.
    info_id = "0-0"
    try:
        last = r.xrevrange(k_stream(args.room), count=1)
        if last:
            info_id = last[0][0]
    except redis.ResponseError:
        pass
    r.set(k_cursor(args.room, args.as_agent), info_id)
    touch_presence(r, args.room, args.as_agent)
    if args.json:
        print(json.dumps({"joined": args.as_agent, "room": args.room, "cursor": info_id}))
    else:
        print(f"{args.as_agent} joined room={args.room} (cursor at {info_id})")
    return 0


def cmd_agents(r, args):
    keys = list(r.scan_iter(match=k_presence(args.room, "*")))
    vals = r.mget(keys) if keys else []
    present = [{"agent": k.rsplit(":", 1)[-1], "last_seen": v}
               for k, v in zip(keys, vals)]
    present.sort(key=lambda a: a["agent"])
    if args.json:
        print(json.dumps(present))
    else:
        if not present:
            print(f"(no agents present in room={args.room})")
        for a in present:
            print(f"{a['agent']}\tlast_seen={a['last_seen']}")
    return 0


def announce(r, room, frm, body, topic=""):
    r.xadd(k_stream(room), make_fields(frm, "all", body, kind="system", topic=topic))


def cmd_claim(r, args):
    """Atomic claim: Redis SET NX wins the race, gh label is the durable record."""
    lock = k_lock(args.issue)
    # Defense against an expired Redis lock: if gh already shows the issue
    # claimed, refuse even though SET NX would succeed. The label outlives the
    # lock TTL, so this stops a second agent double-claiming a long-running task.
    labels = issue_labels(args.issue)
    if labels is None:
        # couldn't read labels -> the cross-check can't run; fall back to the
        # Redis lock alone (the baseline race arbiter) and say so.
        sys.stderr.write(f"warning: could not read labels on #{args.issue}; "
                         f"relying on the Redis lock only for this claim\n")
    elif "status:claimed" in labels:
        held = r.get(lock)
        if held and held != args.as_agent:
            sys.stderr.write(f"issue #{args.issue} already claimed by {held} (label set)\n")
            return 1
        if not held:
            sys.stderr.write(
                f"issue #{args.issue} is labelled status:claimed but the lock expired; "
                f"resolve manually (bus release/status) before reclaiming\n")
            return 1
    won = r.set(lock, args.as_agent, nx=True, ex=args.ttl)
    # `not won` does NOT mean "somebody else has it" — it can also mean WE have it.
    # Connection retries (see connect()) re-send a SET NX whose reply was lost, and
    # the re-send then finds the key its own first attempt created, reporting a loss
    # for the attempt that actually won. So the invocation that truly claimed the
    # issue can land here. Returning early on that path would skip the worktree, the
    # gh label and the announce — leaving an agent holding a claim with no worktree,
    # working the coordinator's main tree, which is exactly what the rollback below
    # exists to prevent. Everything after this is idempotent, so re-running it is
    # both safe and the fix: a re-sent claim, or an operator re-running `bus claim`,
    # converges on the fully set-up state instead of a half-claimed one.
    held_already = False
    if not won:
        holder = r.get(lock)
        if holder != args.as_agent:
            sys.stderr.write(f"issue #{args.issue} already claimed by {holder}\n")
            return 1
        held_already = True
        print(f"you ({args.as_agent}) already hold issue #{args.issue}; ensuring setup")
    # If --worktree, set up isolation BEFORE writing the gh label, so a failure
    # rolls the claim back cleanly — an agent must never hold a claim with no
    # worktree and then silently work the coordinator's main tree.
    if getattr(args, "worktree", False):
        rc, path = ws_create(r, args.room, args.as_agent, args.issue, base=args.base)
        if rc != 0:
            if held_already:
                # The lock predates this invocation — rolling it back would drop a
                # claim we did not create here (and possibly abandon real work).
                sys.stderr.write(f"bus claim: worktree setup failed on #{args.issue}; "
                                 f"keeping the claim you already held\n")
            else:
                r.delete(lock)
                sys.stderr.write(f"bus claim: worktree setup failed; rolled back the claim on #{args.issue}\n")
            return 1
    # We won the lock. Reflect to gh + announce. If gh fails, keep the lock
    # (the announce still tells others), but surface the error.
    err = None
    try:
        set_status_label(args.issue, "status:claimed")
        gh(["issue", "comment", str(args.issue),
            "--body", f"Claimed by `{args.as_agent}` via bus at {now_iso()}."], check=False)
    except Exception as e:  # noqa: BLE001 - report and continue
        err = str(e)
    announce(r, args.room, args.as_agent,
             f"claimed issue #{args.issue}", topic=f"issue-{args.issue}")
    print(f"{args.as_agent} claimed issue #{args.issue}")
    if err:
        sys.stderr.write(f"warning: lock held but gh update failed: {err}\n")
    return 0


def require_holder(r, issue, agent, verb):
    """Return the lock key if `agent` holds the claim, else write an error and
    return None. Shared ownership guard for release/renew."""
    lock = k_lock(issue)
    holder = r.get(lock)
    if holder != agent:
        sys.stderr.write(
            f"cannot {verb} #{issue}: held by {holder or '(nobody)'}, not {agent}\n")
        return None
    return lock


def cmd_release(r, args):
    lock = require_holder(r, args.issue, args.as_agent, "release")
    if not lock:
        return 1
    r.delete(lock)
    # We drop the lock but intentionally leave the status label as-is: releasing
    # gives up ownership without erasing the progress already recorded on the issue.
    announce(r, args.room, args.as_agent,
             f"released issue #{args.issue}", topic=f"issue-{args.issue}")
    print(f"{args.as_agent} released issue #{args.issue}")
    return 0


def cmd_status(r, args):
    set_status_label(args.issue, args.set)
    gh(["issue", "comment", str(args.issue),
        "--body", f"Status -> `{args.set}` by `{args.as_agent}` at {now_iso()}."], check=False)
    # a status update is a sign of life -> renew the claim lock if we hold it
    lock = k_lock(args.issue)
    if r.get(lock) == args.as_agent:
        r.expire(lock, args.ttl)
    announce(r, args.room, args.as_agent,
             f"issue #{args.issue} -> {args.set}", topic=f"issue-{args.issue}")
    print(f"issue #{args.issue} -> {args.set}")
    return 0


def cmd_renew(r, args):
    """Extend the claim lock TTL. Only the holder may renew. Guards long tasks."""
    lock = require_holder(r, args.issue, args.as_agent, "renew")
    if not lock:
        return 1
    r.expire(lock, args.ttl)
    print(f"{args.as_agent} renewed claim on #{args.issue} (+{args.ttl}s)")
    return 0


