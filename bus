def cmd_init(args):
    """Create the status:* labels in the target repo (idempotent via --force)."""
    if not GH_REPO:
        sys.stderr.write("bus init: set BUS_GH_REPO=owner/repo first\n")
        return 2
    for label in STATUS_LABELS:
        gh(["label", "create", label, "--color", _LABEL_COLORS[label],
            "--description", "bus task state", "--force"], check=False)
        print(f"ensured label {label}")
    return 0


def redis_persistence(r):
    """How this Redis would survive a restart: 'aof', 'rdb', or 'none'.

    AOF is what the bus needs — claim locks, the write pen and huddle metadata
    are all live coordination state, and an RDB snapshot loses everything since
    the last save point. Returns None when the mode can't be read (a managed
    Redis may disable CONFIG entirely), which is 'unknown', never 'broken'."""
    try:
        cfg = r.config_get("appendonly", "save")
    except Exception:  # noqa: BLE001 - an unreadable mode is a diagnostic gap, not a fault
        return None
    if not isinstance(cfg, dict):
        return None
    if cfg.get("appendonly") == "yes":
        return "aof"
    return "rdb" if (cfg.get("save") or "").strip() else "none"


def cmd_doctor(r_url):
    ok = True
    # Redis. The connect probe and the persistence probe are reported separately
    # on purpose: a server that is UP but won't answer CONFIG is a healthy bus
    # with an unknown durability mode, and must never be printed as "redis: FAIL".
    try:
        r = connect(r_url)
    except Exception as e:  # noqa: BLE001
        print(f"redis: FAIL ({r_url}) -> {e}")
        print("  start it: ./scripts/start-redis.sh   (or: brew services start redis)")
        ok = False
    else:
        print(f"redis: OK ({r_url})")
        mode = redis_persistence(r)
        if mode == "aof":
            print("redis persistence: OK (appendonly)")
        elif mode is None:
            print("redis persistence: unknown (could not read CONFIG)")
        else:
            # Not a hard failure — a scratch bus is fine volatile — but the pen,
            # the claim locks and huddle metadata all die with the server.
            print(f"redis persistence: WARN ({mode}) — a restart drops claims/pen/huddle state")
            print("  fix: ./scripts/start-redis.sh   (enables appendonly)")
    # gh
    rc, out, err = gh(["auth", "status"], check=False)
    if rc == 0:
        print("gh: OK (authenticated)")
    else:
        print(f"gh: FAIL -> {err or out}")
        ok = False
    try:
        print(f"worktree root: {worktree_root(main_repo_dir())}")
    except Exception:  # noqa: BLE001
        print("worktree root: unavailable")
    try:
        p = subprocess.run(["git", "--version"], capture_output=True, text=True)
        git_version = p.stdout.splitlines()[0] if p.returncode == 0 and p.stdout else "not found"
    except Exception:  # noqa: BLE001
        git_version = "not found"
    print(f"git: {git_version}")
    return 0 if ok else 1


# ---- worktree commands -----------------------------------------------------

def _decode_ws_meta(raw):
    try:
        m = json.loads(raw) if raw else None
    except (TypeError, json.JSONDecodeError):
        return None
    if m and all(k in m for k in ("issue", "agent", "path", "branch", "base_commit")):
        return m
    return None


def _ws_meta(r, issue, agent=None, with_key=False):
    keys = []
    if agent:
        keys.append(k_worktree(issue, agent))
    keys.append(k_worktree(issue))
    for key in keys:
        m = _decode_ws_meta(r.get(key))
        if m:
            return (m, key) if with_key else m
    return (None, None) if with_key else None


def _iter_ws_meta_with_keys(r):
    for key in r.scan_iter(match="bus:worktree:issue:*"):
        m = _decode_ws_meta(r.get(key))
        if m:
            yield key, m


def _iter_ws_meta(r):
    """Yield every registered worktree's metadata dict, skipping malformed or
    legacy entries (missing required keys). Shared by ws list and reap."""
    for _, m in _iter_ws_meta_with_keys(r):
        yield m


def ws_create(r, room, agent, issue, base="dev", branch_type="feat",
              allow_stale=False, allow_nested=False):
    """Core of `ws create` / `claim --worktree`. Returns (rc, path_or_None)."""
    if r.get(k_lock(issue)) != agent:
        sys.stderr.write(f"bus ws create: you ({agent}) must hold the claim on #{issue} "
                         f"(run `bus claim --as {agent} --issue {issue}`) first\n")
        return 1, None
    meta = _ws_meta(r, issue)
    if meta:
        if meta["agent"] == agent and os.path.isdir(meta["path"]):
            return 0, meta["path"]  # resume
        if meta["agent"] != agent:
            sys.stderr.write(f"bus ws create: #{issue} worktree belongs to {meta['agent']} at "
                             f"{meta['path']}; resolve (ws remove) before reclaiming\n")
            return 1, None
        # same agent but the dir is gone -> stale metadata, fall through to recreate
    try:
        main = main_repo_dir()
    except RuntimeError as e:
        sys.stderr.write(f"bus ws create: {e}\n")
        return 1, None
    root = worktree_root(main)
    if path_under(root, main) and not allow_nested:
        sys.stderr.write(f"bus ws create: worktree root {root} is inside the repo {main}; "
                         f"use a sibling dir or pass --allow-nested\n")
        return 1, None
    # A leading '-' would be parsed as a git flag (e.g. base='-p' -> `git fetch
    # origin -p` prunes refs). `ident` and check-ref-format both allow it, so
    # reject it explicitly here — never let base/type become an option token.
    if base.startswith("-") or branch_type.startswith("-"):
        sys.stderr.write(f"bus ws create: base/type must not start with '-' (base={base}, type={branch_type})\n")
        return 1, None
    branch = f"{branch_type}/issue-{issue}-{agent}"
    if not valid_git_ref(main, base) or not valid_git_ref(main, branch):
        sys.stderr.write(f"bus ws create: invalid base/branch ref (base={base}, branch={branch})\n")
        return 1, None
    rc, _, err = git(main, "fetch", "origin", base, check=False)
    if rc != 0 and not allow_stale:
        sys.stderr.write(f"bus ws create: `git fetch origin {base}` failed ({err}); refusing to "
                         f"cut from a possibly-stale base. Fix the network or pass --allow-stale.\n")
        return 1, None
    rc, base_commit, _ = git(main, "rev-parse", "--verify", f"origin/{base}", check=False)
    if rc != 0:
        sys.stderr.write(f"bus ws create: base origin/{base} not found\n")
        return 1, None
    rc, _, _ = git(main, "rev-parse", "--verify", f"refs/heads/{branch}", check=False)
    if rc == 0:
        sys.stderr.write(f"bus ws create: branch {branch} already exists (leftover worktree?); "
                         f"remove it first\n")
        return 1, None
    os.makedirs(root, exist_ok=True)
    path = os.path.abspath(os.path.join(root, f"issue-{issue}-{agent}"))
    rc, _, err = git(main, "worktree", "add", path, "-b", branch, f"origin/{base}", check=False)
    if rc != 0:
        sys.stderr.write(f"bus ws create: git worktree add failed: {err}\n")
        return 1, None
    r.set(k_worktree(issue), json.dumps({
        "issue": issue, "agent": agent, "path": path, "branch": branch,
        "base": base, "base_commit": base_commit, "kind": "solo",
        "detached": False, "created_at": now_iso()}))
    announce(r, room, agent, f"created worktree for #{issue} at {path} (branch {branch})",
             topic=f"issue-{issue}")
    return 0, path


def cmd_ws_create(r, args):
    rc, path = ws_create(r, args.room, args.as_agent, args.issue, base=args.base,
                         branch_type=args.type, allow_stale=args.allow_stale,
                         allow_nested=args.allow_nested)
    if rc == 0:
        print(path)
    return rc


def cmd_ws_path(r, args):
    meta = _ws_meta(r, args.issue)
    if not meta:
        sys.stderr.write(f"bus ws path: no worktree for #{args.issue}\n")
        return 1
    print(meta["path"])
    return 0


def cmd_ws_list(r, args):
    present_set = {k.rsplit(":", 1)[-1] for k in r.scan_iter(match="bus:presence:*")}
    rows = []
    for m in _iter_ws_meta(r):
        path, exists = m["path"], os.path.isdir(m["path"])
        dirty = "gone" if not exists else ("yes" if worktree_dirty(path) else "-")
        unpushed = "yes" if exists and worktree_unpushed(path, m["base_commit"]) else "-"
        present = "yes" if m["agent"] in present_set else "no"
        kind = m.get("kind", "solo")
        detached = bool(m.get("detached", False))
        rows.append((m["issue"], kind, detached, m["agent"], m["branch"],
                     path, dirty, unpushed, present))
    rows.sort(key=lambda x: int(x[0]) if str(x[0]).isdigit() else 0)
    if args.json:
        print(json.dumps([{"issue": i, "kind": k, "detached": dt, "agent": a,
                           "branch": b, "path": p, "dirty": d,
                           "unpushed": u, "present": pr}
                          for i, k, dt, a, b, p, d, u, pr in rows]))
        return 0
    if not rows:
        print("(no agent worktrees)")
        return 0
    print(f"{'ISSUE':<6} {'KIND':<8} {'AGENT':<12} {'BRANCH':<26} {'DIRTY':<6} {'UNPUSH':<7} {'PRES':<4} PATH")
    for i, k, dt, a, b, p, d, u, pr in rows:
        label = f"{k}{'*' if dt else ''}"
        print(f"#{str(i):<5} {terminal_line(label):<8} {terminal_line(a):<12} {terminal_line(b):<26} "
              f"{d:<6} {u:<7} {pr:<4} {terminal_line(p)}")
    return 0


def cmd_ws_remove(r, args):
    meta, meta_key = _ws_meta(r, args.issue, agent=args.as_agent, with_key=True)
    if not meta and args.force:
        matches = [(k, m) for k, m in _iter_ws_meta_with_keys(r)
                   if str(m["issue"]) == str(args.issue)]
        if len(matches) == 1:
            meta_key, meta = matches[0]
        elif len(matches) > 1:
            owners = ", ".join(sorted(m["agent"] for _, m in matches))
            sys.stderr.write(f"bus ws remove: #{args.issue} has multiple worktrees "
                             f"({owners}); rerun with --as <owner> --force\n")
            return 1
    if not meta:
        sys.stderr.write(f"bus ws remove: no worktree for #{args.issue} owned by {args.as_agent}\n")
        return 1
    if meta["agent"] != args.as_agent and not args.force:
        sys.stderr.write(f"bus ws remove: #{args.issue} worktree belongs to {meta['agent']}, "
                         f"not {args.as_agent}; --force to override\n")
        return 1
    path = meta["path"]
    try:
        main = main_repo_dir()
        root = worktree_root(main)
    except RuntimeError as e:
        sys.stderr.write(f"bus ws remove: {e}\n")
        return 1
    # only ever remove a registered path under our own worktree root
    if not path_under(path, root):
        sys.stderr.write(f"bus ws remove: refusing — {path} is not under the worktree root {root}\n")
        return 1
    if path_under(os.getcwd(), path):
        sys.stderr.write(f"bus ws remove: you are inside {path}; run from the main tree\n")
        return 1
    if os.path.isdir(path) and not args.force:
        if worktree_dirty(path):
            sys.stderr.write(f"bus ws remove: #{args.issue} has uncommitted changes; "
                             f"commit/stash or --force to discard\n")
            return 1
        if worktree_unpushed(path, meta["base_commit"]):
            sys.stderr.write(f"bus ws remove: #{args.issue} has unpushed commits; "
                             f"push first or --force to discard\n")
            return 1
    rm = ["worktree", "remove", path] + (["--force"] if args.force else [])
    rc, _, err = git(main, *rm, check=False)
    if rc != 0 and os.path.isdir(path):
        sys.stderr.write(f"bus ws remove: git worktree remove failed: {err}\n")
        return 1
    r.delete(meta_key)
    announce(r, args.room, args.as_agent, f"removed worktree for #{args.issue}",
             topic=f"issue-{args.issue}")
    print(f"removed worktree for #{args.issue} ({path})")
    return 0


def cmd_ws(r, args):
    return {"create": cmd_ws_create, "path": cmd_ws_path,
            "list": cmd_ws_list, "remove": cmd_ws_remove}[args.ws_cmd](r, args)


# ---- huddle commands (stage 1 of #22) --------------------------------------
# A huddle is collaborative co-work on ONE issue (many agents, one branch). This
# stage is session lifecycle ONLY: open/join/status/close + metadata. Pen
# adjudication, critique, signoff and the done-gate are deferred to later stages.

def huddle_holder(issue):
    """Legacy deterministic huddle holder kept for old metadata compatibility."""
    return f"huddle:issue-{issue}"


def new_huddle_holder(issue):
    """Unique holder for one huddle session, recognizable by _is_huddle_lock."""
    return f"{huddle_holder(issue)}:{secrets.token_urlsafe(16)}"


def huddle_meta_holder(meta, issue):
    """Session holder from metadata, falling back to pre-token huddle metadata."""
    return meta.get("session") or meta.get("holder") or huddle_holder(issue)


def huddle_branch(issue):
    return f"huddle/issue-{issue}"


def _huddle_meta(r, issue):
    raw = r.get(k_huddle(issue))
    return json.loads(raw) if raw else None


_NO_HUDDLE_SESSION = object()


def _set_driver(r, issue, driver, *, pen_to, pen_expect,
                clear_challenge=False, expected_session=None,
                driver_must_be_participant=False, challenge_expect=None):
    """Move the pen and rewrite the huddle's `driver`, in one transaction.

    The metadata is one JSON blob, so a read-modify-SET of it is a lost-update
    race against `huddle join`, which grows `participants` under its own
    WATCH/MULTI: a join committing between the read and the SET is silently
    erased, and the done-gate then closes the huddle with that participant
    present and never signed off. Re-reading the whole dict inside the watched
    window is what keeps the join.

    Not `_mutate_json`: that recreates a deleted key from `default` (resurrecting
    a closed huddle as a participant-less stub) and has no abort path.

    `pen_to`/`pen_expect` are required, not defaulted: every caller is moving the
    pen, and the pen key is written in the SAME transaction as the metadata. That
    makes the result load-bearing — a closed huddle or a pen that moved under the
    caller aborts before `k_pen` changes, so no pen key is seeded on a huddle that
    is already gone. There is no "rewrite the driver but ignore the pen" mode; a
    caller that wants one has to say what it expects the pen to be, and where it
    is sending it. (Releasing the pen is `_release_pen_driver`, not this.)

    `expected_session` binds a stale caller to the exact huddle it read before
    any checkpoint/presence/race window. Issue numbers are reusable after
    close+reopen, so checking only the pen holder is not enough.

    Returns True if the pen and driver were written; False if the huddle is gone,
    or `expected_session` / `pen_expect` / `challenge_expect` did not match, or
    `driver` is not a current participant. Every caller acts on the result.
    Corrupt metadata raises (like `_huddle_meta`) rather than silently no-opping
    — a driver write we can't complete must be loud.
    """
    key = k_huddle(issue)
    pen_key = k_pen(issue)
    chal_key = k_penchal(issue) if clear_challenge else None
    with r.pipeline() as pipe:
        while True:
            try:
                watch_keys = [key, pen_key]
                if chal_key:
                    watch_keys.append(chal_key)
                pipe.watch(*watch_keys)
                raw = pipe.get(key)
                if not raw:
                    pipe.unwatch()
                    return False
                meta = json.loads(raw)
                if expected_session is not None and huddle_meta_holder(meta, issue) != expected_session:
                    pipe.unwatch()
                    return False
                if driver_must_be_participant and driver not in meta.get("participants", []):
                    pipe.unwatch()
                    return False
                current_pen = pipe.get(pen_key)
                current_chal = pipe.get(chal_key) if chal_key else None
                # The move we were asked to make is ALREADY in place. Redis can lose
                # an EXEC reply, so a retry of a transaction that landed must report
                # success, not a phantom conflict — the mismatch below is then our own
                # completed write, not a competing one.
                already_done = (current_pen == pen_to
                                and meta.get("driver") == driver
                                and current_chal is None)
                if challenge_expect is not None and current_chal != challenge_expect:
                    pipe.unwatch()
                    return already_done
                if current_pen != pen_expect:
                    pipe.unwatch()
                    return already_done
                meta["driver"] = driver
                pipe.multi()
                pipe.set(pen_key, pen_to)
                pipe.set(key, json.dumps(meta))
                if chal_key:
                    pipe.delete(chal_key)
                pipe.execute()
                return True
            except redis.WatchError:
                continue  # a join (or another pen op) landed; re-read and retry


def _release_pen_driver(r, issue, agent, expected_session):
    """Release `agent`'s pen and clear huddle.driver in one watched update.

    A drain snapshots pens before it releases them. If the issue closes and
    reopens in that window, the new huddle may legitimately have the same agent
    holding the pen; `expected_session` prevents the stale drain from deleting
    that new pen. The already-released branch is intentional: if Redis lost the
    EXEC reply and retries the transaction after the first attempt landed, the
    second pass sees pen gone + driver blank and still reports success.
    """
    huddle_key = k_huddle(issue)
    pen_key = k_pen(issue)
    with r.pipeline() as pipe:
        while True:
            try:
                pipe.watch(huddle_key, pen_key)
                raw = pipe.get(huddle_key)
                current_pen = pipe.get(pen_key)
                if expected_session is _NO_HUDDLE_SESSION:
                    if raw:
                        pipe.unwatch()
                        return False
                    if current_pen == agent:
                        pipe.multi()
                        pipe.delete(pen_key)
                        pipe.execute()
                        return True
                    pipe.unwatch()
                    return current_pen is None
                if not raw:
                    pipe.unwatch()
                    return False
                meta = json.loads(raw)
                if huddle_meta_holder(meta, issue) != expected_session:
                    pipe.unwatch()
                    return False
                if current_pen == agent and meta.get("driver") == agent:
                    meta["driver"] = ""
                    pipe.multi()
                    pipe.delete(pen_key)
                    pipe.set(huddle_key, json.dumps(meta))
                    pipe.execute()
                    return True
                pipe.unwatch()
                return current_pen is None and meta.get("driver") == ""
            except redis.WatchError:
                continue


def _record_pen_challenge(r, issue, challenger, reason, expected_session, expected_driver):
    """Record/refresh a challenge only for the huddle and pen holder observed."""
    huddle_key = k_huddle(issue)
    pen_key = k_pen(issue)
    chal_key = k_penchal(issue)
    with r.pipeline() as pipe:
        while True:
            try:
                pipe.watch(huddle_key, pen_key, chal_key)
                raw = pipe.get(huddle_key)
                if not raw:
                    pipe.unwatch()
                    return False
                meta = json.loads(raw)
                if huddle_meta_holder(meta, issue) != expected_session:
                    pipe.unwatch()
                    return False
                if challenger not in meta.get("participants", []):
                    pipe.unwatch()
                    return False
                if pipe.get(pen_key) != expected_driver:
                    pipe.unwatch()
                    return False
                pipe.multi()
                pipe.set(chal_key, json.dumps({
                    "challenger": challenger,
                    "reason": reason,
                    "ts": now_iso(),
                    "session": expected_session,
                    "driver": expected_driver,
                }))
                pipe.execute()
                return True
            except redis.WatchError:
                continue


def _delete_huddle_state(r, issue, expected_session):
    """Delete huddle volatile keys only if metadata still belongs to this session."""
    huddle_key = k_huddle(issue)
    with r.pipeline() as pipe:
        while True:
            try:
                pipe.watch(huddle_key)
                raw = pipe.get(huddle_key)
                if raw:
                    meta = json.loads(raw)
                    if huddle_meta_holder(meta, issue) != expected_session:
                        pipe.unwatch()
                        return False
                pipe.multi()
                if raw:
                    pipe.delete(huddle_key, k_pen(issue), k_penchal(issue),
                                k_signoff(issue), k_block(issue))
                pipe.execute()
                return True
            except redis.WatchError:
                continue


def _delete_pen_challenge(r, issue, driver, challenge_raw):
    """Delete a challenge only if it is still the same challenge for this session."""
    chal_key = k_penchal(issue)
    huddle_key = k_huddle(issue)
    pen_key = k_pen(issue)
    try:
        chal = json.loads(challenge_raw)
    except json.JSONDecodeError:
        raise
    expected_session = chal.get("session")
    if not expected_session or chal.get("driver") != driver:
        return False
    with r.pipeline() as pipe:
        while True:
            try:
                pipe.watch(huddle_key, pen_key, chal_key)
                if pipe.get(chal_key) != challenge_raw:
                    pipe.unwatch()
                    return False
                raw = pipe.get(huddle_key)
                if not raw:
                    pipe.unwatch()
                    return False
                meta = json.loads(raw)
                if huddle_meta_holder(meta, issue) != expected_session:
                    pipe.unwatch()
                    return False
                if pipe.get(pen_key) != driver:
                    pipe.unwatch()
                    return False
                pipe.multi()
                pipe.delete(chal_key)
                pipe.execute()
                return True
            except redis.WatchError:
                continue


def create_shared_branch(main, base, branch, allow_stale=False):
    """Push an empty `branch` at origin/`base`'s tip. Returns (rc, base_commit_or_err).
    No worktree is created here — per-driver worktrees are a later (pen) stage."""
    if base.startswith("-"):
        return 1, "base must not start with '-'"
    if not valid_git_ref(main, base) or not valid_git_ref(main, branch):
        return 1, f"invalid base/branch ref (base={base}, branch={branch})"
    rc, _, err = git(main, "fetch", "origin", base, check=False)
    if rc != 0 and not allow_stale:
        return 1, (f"`git fetch origin {base}` failed ({err}); refusing to cut from a "
                   f"possibly-stale base. Fix the network or pass --allow-stale.")
    rc, base_commit, _ = git(main, "rev-parse", "--verify", f"origin/{base}", check=False)
    if rc != 0:
        return 1, f"base origin/{base} not found"
    rc, out, _ = git(main, "ls-remote", "--heads", "origin", branch, check=False)
    if rc == 0 and out.strip():
        return 1, f"remote branch {branch} already exists (leftover huddle?); remove it first"
    # Atomic create. A plain `push base:refs/heads/branch` is create-OR-fast-forward:
    # if a racing writer created `branch` between the ls-remote check above and this
    # push, it would silently fast-forward THEIR branch (or no-op on an equal tip)
    # instead of failing. Empty-expect `--force-with-lease=refs/heads/branch:` requires
    # the remote ref to NOT exist, so a race is rejected (stale info); `--porcelain`
    # lets us confirm we actually created it (`[new branch]`) rather than any other
    # outcome. (B2 git-ref collision hardening; see #82.)
    rc, out, err = git(main, "push", "--porcelain",
                       f"--force-with-lease=refs/heads/{branch}:",
                       "origin", f"{base_commit}:refs/heads/{branch}", check=False)
    if rc != 0 or "[new branch]" not in out:
        return 1, (f"atomic create of {branch} failed (racing writer or leftover branch?); "
                   f"refusing to fast-forward an existing ref: {err or out or 'no [new branch]'}")
    return 0, base_commit


def cleanup_shared_branch(main, branch, expected_commit):
    """Delete remote huddle branch only if still at expected_commit."""
    if not expected_commit:
        return 1, "missing expected branch commit"
    if not valid_git_ref(main, branch):
        return 1, f"invalid branch ref {branch}"
    rc, out, err = git(main, "ls-remote", "--heads", "origin", branch, check=False)
    if rc != 0:
        return 1, f"could not inspect remote branch {branch}: {err}"
    if not out.strip():
        return 0, f"remote branch {branch} already absent"
    remote_commit = out.split()[0]
    if remote_commit != expected_commit:
        return 1, (f"remote branch {branch} moved to {remote_commit}; "
                   f"left it intact")
    lease = f"refs/heads/{branch}:{expected_commit}"
    rc, _, err = git(main, "push", f"--force-with-lease={lease}",
                     "origin", f":refs/heads/{branch}", check=False)
    if rc != 0:
        return 1, f"could not delete remote branch {branch}: {err}"
    return 0, f"deleted remote branch {branch}"


def cleanup_lost_huddle_branch(r, issue, main, branch, expected_commit):
    """Clean up an orphan branch only when no newer huddle owns this issue."""
    holder = r.get(k_lock(issue))
    if holder:
        return 1, f"left remote branch {branch} intact; issue lock now held by {holder}"
    if r.get(k_huddle(issue)):
        return 1, f"left remote branch {branch} intact; huddle metadata now exists"
    return cleanup_shared_branch(main, branch, expected_commit)


def cmd_huddle_open(r, args):
    """Open a huddle: take the issue lock as the huddle session, create the shared
    branch off origin/<base>, mark the issue claimed, record metadata, announce."""
    issue = args.issue
    lock = k_lock(issue)
    branch = huddle_branch(issue)
    session = new_huddle_holder(issue)
    # Metadata has no TTL and outlives the lock; if it's present a huddle already
    # exists (or a prior one wasn't closed) — refuse before touching the lock.
    if _huddle_meta(r, issue):
        sys.stderr.write(f"bus huddle open: #{issue} already has an active huddle "
                         f"(run `bus huddle close` to end it)\n")
        return 1
    try:
        main = main_repo_dir()
    except RuntimeError as e:
        sys.stderr.write(f"bus huddle open: {e}\n")
        return 1
    # Defense against an expired solo lock: if gh already shows the issue
    # claimed but the Redis lock has lapsed, refuse — the durable label outlives
    # the TTL, so a solo `bus claim` in flight must not be stolen by a huddle
    # (mirrors cmd_claim's cross-check).
    labels = issue_labels(issue)
    if labels is None:
        sys.stderr.write(f"warning: could not read labels on #{issue}; relying on "
                         f"the Redis lock only for this huddle open\n")
    elif "status:claimed" in labels:
        held = r.get(lock)
        if held and not _is_huddle_lock(held):
            sys.stderr.write(f"bus huddle open: #{issue} already claimed by {held} "
                             f"(label set)\n")
            return 1
        if not held:
            sys.stderr.write(
                f"bus huddle open: #{issue} is labelled status:claimed but the lock "
                f"expired; resolve manually (bus release/status) before opening a huddle\n")
            return 1
    won = r.set(lock, session, nx=True, ex=args.ttl)
    if not won and r.get(lock) != session:
        sys.stderr.write(f"bus huddle open: issue #{issue} already locked by {r.get(lock)}\n")
        return 1
    # `not won` but the lock already holds OUR session token: a connection retry
    # re-sent this very SET NX after its reply was lost, so our own first attempt
    # is what's in there. The token is 16 random bytes, so nobody else can be
    # holding it — proceed as the winner. Bailing out here instead would strand the
    # issue under a phantom huddle lock with no metadata and no branch, which
    # `bus reap` deliberately refuses to free (_is_huddle_lock) and `bus release`
    # cannot touch — an unrecoverable lock short of a manual redis-cli DEL.
    # Set up the shared branch BEFORE the gh label, so a failure rolls the lock
    # back cleanly — no huddle should hold the issue lock with no branch.
    rc, val = create_shared_branch(main, args.base, branch, allow_stale=args.allow_stale)
    if rc != 0:
        # Compare-and-delete, not a blind delete: if our short TTL already lapsed
        # and another session re-took the lock, a plain delete would nuke THEIRS.
        compare_delete_lock(r, issue, session)
        sys.stderr.write(f"bus huddle open: {val}; rolled back the lock on #{issue}\n")
        return 1
    base_commit = val
    meta_json = json.dumps({
        "issue": issue, "opener": args.as_agent, "participants": [args.as_agent],
        "driver": args.as_agent, "branch": branch, "base": args.base,
        "base_commit": base_commit, "session": session, "status": "open",
        "created_at": now_iso()})
    if not compare_set_huddle_meta(r, issue, session, meta_json, pen_holder=args.as_agent):
        rc, cleanup_msg = cleanup_lost_huddle_branch(r, issue, main, branch, base_commit)
        sys.stderr.write(
            f"bus huddle open: lost lock on #{issue} after branch creation; "
            f"aborted before metadata/GitHub writes. {cleanup_msg}\n")
        return 1
    touch_presence(r, args.room, args.as_agent)
    # gh is best-effort: the lock + branch + metadata already exist, so a gh
    # outage must not abort a live huddle (mirrors cmd_claim).
    err = None
    try:
        set_status_label(issue, "status:claimed")
        gh(["issue", "comment", str(issue),
            "--body", f"Huddle opened by `{args.as_agent}` via bus at {now_iso()} "
                      f"(branch `{branch}`)."], check=False)
    except Exception as e:  # noqa: BLE001 - report and continue
        err = str(e)
    announce(r, args.room, args.as_agent,
             f"opened huddle on #{issue} (branch {branch}, driver {args.as_agent})",
             topic=f"issue-{issue}")
    print(f"{args.as_agent} opened huddle on #{issue} (branch {branch})")
    if err:
        sys.stderr.write(f"warning: huddle open but gh update failed: {err}\n")
    return 0


def cmd_huddle_join(r, args):
    """Add the agent to the huddle participants. Open join for stage 1 (admission
    rule deferred). A WATCH/MULTI loop makes concurrent joins safe (no lost add)."""
    issue = args.issue
    key = k_huddle(issue)
    # Refuse to append to a zombie: metadata has no TTL, so it can outlive a
    # lapsed (expired/reaped) session lock. If the lock is gone the huddle is
    # dead — don't join it. Advisory (pen/write-authority is deferred), so the
    # benign TOCTOU between this check and the add just appends to metadata.
    raw = r.get(key)
    if not raw:
        sys.stderr.write(f"bus huddle join: no huddle on #{issue}\n")
        return 1
    try:
        meta = json.loads(raw)
    except json.JSONDecodeError:
        sys.stderr.write(f"bus huddle join: corrupt huddle metadata on #{issue}\n")
        return 1
    holder = huddle_meta_holder(meta, issue)
    if r.get(k_lock(issue)) != holder:
        sys.stderr.write(f"bus huddle join: #{issue}'s huddle lock is gone "
                         f"(expired or reaped); ask the opener to reopen it\n")
        return 1
    lock_key = k_lock(issue)
    with r.pipeline() as pipe:
        while True:
            try:
                pipe.watch(key, lock_key)
                raw = pipe.get(key)
                if not raw:
                    pipe.unwatch()
                    sys.stderr.write(f"bus huddle join: no huddle on #{issue}\n")
                    return 1
                try:
                    meta = json.loads(raw)
                except json.JSONDecodeError:
                    pipe.unwatch()
                    sys.stderr.write(f"bus huddle join: corrupt huddle metadata on #{issue}\n")
                    return 1
                holder = huddle_meta_holder(meta, issue)
                if pipe.get(lock_key) != holder:
                    pipe.unwatch()
                    sys.stderr.write(f"bus huddle join: #{issue}'s huddle lock is gone "
                                     f"(expired or reaped); ask the opener to reopen it\n")
                    return 1
                if args.as_agent in meta["participants"]:
                    pipe.unwatch()
                    break
                meta["participants"].append(args.as_agent)
                pipe.multi()
                pipe.set(key, json.dumps(meta))
                pipe.execute()
                break
            except redis.WatchError:
                continue  # another join landed between watch and exec; retry
    touch_presence(r, args.room, args.as_agent)
    announce(r, args.room, args.as_agent, f"joined huddle on #{issue}",
             topic=f"issue-{issue}")
    print(f"{args.as_agent} joined huddle on #{issue}")
    return 0


def cmd_huddle_status(r, args):
    meta = _huddle_meta(r, args.issue)
    if not meta:
        sys.stderr.write(f"bus huddle status: no huddle on #{args.issue}\n")
        return 1
    if args.json:
        print(json.dumps(meta))
        return 0
    print(f"huddle #{terminal_line(str(meta['issue']))}  status={terminal_line(meta['status'])}")
    print(f"  opener:       {terminal_line(meta['opener'])}")
    print(f"  driver:       {terminal_line(meta['driver'])}")
    print(f"  branch:       {terminal_line(meta['branch'])}")
    print(f"  participants: {', '.join(terminal_line(p) for p in meta['participants'])}")
    return 0


def cmd_huddle_close(r, args):
    """Close the huddle: mark the issue pr-open, drop the lock + metadata. Gated
    by the DONE-GATE — every present participant signed off at the current tip and
    no open blocks — unless --force. Participant-only (stops a bystander closing)."""
    issue = args.issue
    meta = _huddle_meta(r, issue)
    if not meta:
        sys.stderr.write(f"bus huddle close: no huddle on #{issue}\n")
        return 1
    if args.as_agent not in meta["participants"]:
        sys.stderr.write(f"bus huddle close: {args.as_agent} is not a participant of "
                         f"#{issue}'s huddle; only participants may close\n")
        return 1
    touch_presence(r, args.room, args.as_agent)
    # DONE-GATE (stage 3): the GROUP owns "perfect" — refuse to close until the
    # closer + every present participant has signed off at the current tip and no
    # block is open.
    if not getattr(args, "force", False):
        ok, reasons = donegate(r, issue, meta, args.as_agent)
        if not ok:
            # Structured signal (B6, #81): surface the blocked close for tooling.
            # Emit the COUNT of open reasons only — the reason strings embed
            # untrusted user --block text and must never ride the event layer.
            announce_event(r, args.room, args.as_agent, EV_DONEGATE_BLOCK,
                           {"issue": issue, "closer": args.as_agent,
                            "open_reasons": len(reasons)},
                           topic=f"issue-{issue}")
            sys.stderr.write(f"bus huddle close: #{issue} not done — {len(reasons)} open:\n")
            for why in reasons:
                sys.stderr.write(f"  - {why}\n")
            sys.stderr.write("  resolve, or `--force` to close anyway.\n")
            return 1
    # Advance the label ONLY if we still legitimately hold the session lock.
    # compare_delete_lock returns 1 iff the lock was ours (atomic, no TOCTOU); a
    # 0 means it already expired or was reaped — possibly re-acquired by someone
    # else — so advancing status:pr-open would clobber their state. Cleanup is
    # also session-bound: a delayed close must not delete a reopened huddle.
    session = huddle_meta_holder(meta, issue)
    owned = compare_delete_lock(r, issue, session)
    err = None
    if owned:
        try:
            set_status_label(issue, "status:pr-open")
            gh(["issue", "comment", str(issue),
                "--body", f"Huddle closed by `{args.as_agent}` via bus at {now_iso()}."],
               check=False)
        except Exception as e:  # noqa: BLE001 - report and continue
            err = str(e)
    if not _delete_huddle_state(r, issue, session):
        sys.stderr.write(f"bus huddle close: huddle #{issue} changed sessions while closing; "
                         "left current huddle state intact\n")
        return 1
    announce(r, args.room, args.as_agent, f"closed huddle on #{issue}",
             topic=f"issue-{issue}")
    print(f"{args.as_agent} closed huddle on #{issue}")
    if not owned:
        sys.stderr.write(f"warning: huddle #{issue} lock was already gone (expired or "
                         f"reaped); cleared metadata but did NOT advance the status "
                         f"label — set it manually if the issue still needs it\n")
    elif err:
        sys.stderr.write(f"warning: huddle closed but gh update failed: {err}\n")
    return 0


def register_huddle_worktree(r, issue, agent, path, branch, shared):
    huddle = _huddle_meta(r, issue) or {}
    old = _decode_ws_meta(r.get(k_worktree(issue, agent))) or {}
    r.set(k_worktree(issue, agent), json.dumps({
        "issue": issue, "agent": agent, "path": os.path.abspath(path),
        "branch": branch, "base": huddle.get("base", ""),
        "base_commit": huddle.get("base_commit", ""),
        "kind": "huddle", "detached": True, "shared_branch": shared,
        "created_at": old.get("created_at", now_iso())}))


def huddle_worktree(r, main, issue, agent):
    """Ensure `agent` has a per-driver worktree for the huddle, fast-forwarded to
    the shared branch's tip. Per-driver worktrees give OS-level isolation (the
    ratified design); the SHARED source of truth is origin/huddle/issue-N, which
    only the pen holder pushes to. Returns the path, or None on error."""
    root = worktree_root(main)
    shared = huddle_branch(issue)                 # remote shared branch
    local = f"hw-{issue}-{agent}"                 # this driver's local branch
    path = os.path.join(root, f"huddle-{issue}-{agent}")
    git(main, "fetch", "origin", shared, check=False)
    rc, _, _ = git(main, "rev-parse", "--verify", f"origin/{shared}", check=False)
    if rc != 0:
        sys.stderr.write(f"huddle pen: shared branch origin/{shared} not found\n")
        return None
    if os.path.isdir(path):
        # Sync to the shared tip, but NEVER lose work. Reset only when the tree is
        # clean AND HEAD is an ancestor of the shared tip (a pure fast-forward —
        # nothing local to lose). A clean tree can still hold committed-but-unpushed
        # commits (e.g. a prior push failed); those are ahead of shared, so we skip
        # the reset and warn rather than `reset --hard` them away.
        rc, out, _ = git(path, "status", "--porcelain", check=False)
        if not out.strip():
            rc, _, _ = git(path, "merge-base", "--is-ancestor", "HEAD",
                          f"origin/{shared}", check=False)
            if rc == 0:
                git(path, "reset", "--hard", f"origin/{shared}", check=False)
            else:
                sys.stderr.write(f"huddle pen: #{issue} worktree has local commits not "
                                 f"on origin/{shared}; not resetting (push them first)\n")
        register_huddle_worktree(r, issue, agent, path, local, shared)
        return path
    os.makedirs(root, exist_ok=True)
    rc, _, err = git(main, "worktree", "add", path, "-B", local, f"origin/{shared}", check=False)
    if rc != 0:
        sys.stderr.write(f"huddle pen: worktree add failed: {err}\n")
        return None
    register_huddle_worktree(r, issue, agent, path, local, shared)
    return path


def _require_pen(r, issue, agent, verb):
    holder = r.get(k_pen(issue))
    if holder != agent:
        sys.stderr.write(f"bus pen {verb}: you ({agent}) don't hold the pen on #{issue} "
                         f"(holder: {holder or '(none)'})\n")
        return False
    return True


def cmd_pen_status(r, args):
    issue = args.issue
    holder = r.get(k_pen(issue))
    if not holder:
        sys.stderr.write(f"bus pen status: no pen on #{issue} (no active huddle?)\n")
        return 1
    tip = "?"
    try:
        main = main_repo_dir()
        git(main, "fetch", "origin", huddle_branch(issue), check=False)
        rc, out, _ = git(main, "rev-parse", "--short", f"origin/{huddle_branch(issue)}", check=False)
        if rc == 0:
            tip = out
    except RuntimeError:
        pass
    if args.json:
        print(json.dumps({"issue": issue, "holder": holder, "branch": huddle_branch(issue), "tip": tip}))
    else:
        print(f"pen #{issue}: holder={terminal_line(holder)}  branch={huddle_branch(issue)}  tip={tip}")
    return 0


def _synced_tip(path, shared):
    """The origin/<shared> tip huddle_worktree just fetched — the commit our push must
    lease against. Deliberately NOT a re-fetch: a re-fetch would silently adopt a racing
    writer's push as our base and defeat the collision guard. Returns the sha, or None if
    the shared ref can't be resolved (huddle_worktree should have caught that first)."""
    rc, tip, _ = git(path, "rev-parse", "--verify", f"origin/{shared}", check=False)
    return tip if rc == 0 else None


def _leased_push(path, shared, integrated):
    """Push worktree HEAD to origin/`shared`, LEASED against `integrated` (the tip we
    last synced down), then VERIFY the remote actually advanced to our HEAD.

    The pen is meant to guarantee a single writer, but a git-ref collision (a racing
    push/branch/delete against the same origin) can still move the shared ref between
    our sync and our push. A plain push would then be rejected as non-ff (noisy) or, if
    the remote moved to a commit our HEAD still fast-forwards, advance a base we never
    reviewed. Leasing against `integrated` makes a moved ref REJECT (never clobbers a
    peer's commit); the post-push ls-remote check catches a mismatch (e.g. our push
    half-landed then got overwritten).

    Returns (rc, head_sha, err): rc 0 = pushed and verified; rc 1 = BLOCKING
    (lease reject or post-push mismatch — caller must not advance any state)."""
    rc, head, _ = git(path, "rev-parse", "HEAD", check=False)
    # Never force a non-ff: HEAD must descend from the tip we're leasing against, or a
    # lease-authorized force could discard the commit currently on `integrated`.
    rc2, _, _ = git(path, "merge-base", "--is-ancestor", integrated, "HEAD", check=False)
    if rc2 != 0:
        return 1, head, (f"HEAD {head[:8]} does not descend from the synced tip "
                         f"{integrated[:8]}; refusing to force (diverged — recover manually)")
    lease = f"refs/heads/{shared}:{integrated}"
    rc3, out, err = git(path, "push", "--porcelain", f"--force-with-lease={lease}",
                        "origin", f"HEAD:{shared}", check=False)
    if rc3 != 0:
        # B6-TODO(#81): emit structured event type="lease-reject" (BLOCKING) here.
        return 1, head, (f"leased push rejected — another writer moved {shared} since our "
                         f"last sync (git-ref collision): {err or out}")
    rc4, rout, _ = git(path, "ls-remote", "--heads", "origin", shared, check=False)
    remote_sha = rout.split()[0] if (rc4 == 0 and rout.strip()) else ""
    if remote_sha != head:
        # B6-TODO(#81): emit structured event type="post-push-mismatch" (BLOCKING) here.
        return 1, head, (f"post-push mismatch: remote {shared} is {remote_sha[:8] or '(none)'}, "
                         f"expected {head[:8]}; run `bus huddle recover`")
    return 0, head, ""


def cmd_pen_checkpoint(r, args):
    """Pen holder: stage + commit + push WIP to the shared branch (one command —
    MB-SPEED: no manual git ceremony). The push is leased against the tip we synced
    down (via `_leased_push`) so a git-ref collision is rejected, never clobbered."""
    issue = args.issue
    if not _require_pen(r, issue, args.as_agent, "checkpoint"):
        return 1
    touch_presence(r, args.room, args.as_agent)  # driving = live (not force-takeable)
    try:
        main = main_repo_dir()
    except RuntimeError as e:
        sys.stderr.write(f"bus pen checkpoint: {e}\n")
        return 1
    path = huddle_worktree(r, main, issue, args.as_agent)
    if not path:
        return 1
    integrated = _synced_tip(path, huddle_branch(issue))
    if not integrated:
        sys.stderr.write(f"bus pen checkpoint: cannot resolve synced tip of "
                         f"origin/{huddle_branch(issue)} on #{issue}\n")
        return 1
    git(path, "add", "-A", check=False)
    rc, _, _ = git(path, "diff", "--cached", "--quiet", check=False)
    if rc != 0:  # staged changes -> commit them
        git(path, "-c", f"user.email={args.as_agent}@bus", "-c", f"user.name={args.as_agent}",
            "commit", "-m", f"wip: #{issue} checkpoint by {args.as_agent}", check=False)
    # nothing to send only if HEAD is already at/behind the shared tip (no new
    # commit AND no prior committed-but-unpushed work).
    rc, _, _ = git(path, "merge-base", "--is-ancestor", "HEAD",
                  f"origin/{huddle_branch(issue)}", check=False)
    if rc == 0:
        print(f"pen checkpoint: nothing to commit on #{issue}")
        return 0
    # push HEAD to the shared branch, leased against the synced tip (flushes a fresh
    # commit AND any prior unpushed commits a retry is recovering). A moved ref is
    # rejected, not clobbered; a post-push mismatch is caught.
    rc, head, err = _leased_push(path, huddle_branch(issue), integrated)
    if rc != 0:
        sys.stderr.write(f"bus pen checkpoint: {err}\n")
        return 1
    tip = head[:7]
    announce(r, args.room, args.as_agent, f"checkpointed #{issue} (tip {tip})",
             topic=f"issue-{issue}")
    print(f"{args.as_agent} checkpointed #{issue} to {huddle_branch(issue)} (tip {tip})")
    return 0


def cmd_pen_pass(r, args):
    """Hand the pen to another participant. Commit+push our WIP FIRST (no
    uncommitted work crosses a handoff), then move the pen. Only the current
    holder may pass; only to a huddle participant."""
    issue = args.issue
    if not _require_pen(r, issue, args.as_agent, "pass"):
        return 1
    touch_presence(r, args.room, args.as_agent)
    meta = _huddle_meta(r, issue)
    if not meta:
        sys.stderr.write(f"bus pen pass: no huddle on #{issue}\n")
        return 1
    session = huddle_meta_holder(meta, issue)
    if args.to not in meta["participants"]:
        sys.stderr.write(f"bus pen pass: {args.to} is not a participant of #{issue}'s "
                         f"huddle (they must `bus huddle join` first)\n")
        return 1
    # checkpoint our work before the handoff; ABORT if it fails to push, so we
    # never move the pen with committed work stranded off the shared branch.
    if cmd_pen_checkpoint(r, args) != 0:
        sys.stderr.write(f"bus pen pass: checkpoint failed to push; keeping the pen with "
                         f"{args.as_agent}. Fix the push, then retry the pass.\n")
        return 1
    if not _set_driver(r, issue, args.to, pen_to=args.to, pen_expect=args.as_agent,
                       clear_challenge=True, expected_session=session,
                       driver_must_be_participant=True):
        sys.stderr.write(f"bus pen pass: huddle or pen changed while passing #{issue}; "
                         "not moving the pen\n")
        return 1
    announce(r, args.room, args.as_agent, f"passed the pen on #{issue} to {args.to}",
             topic=f"issue-{issue}")
    print(f"{args.as_agent} passed the pen on #{issue} to {args.to}")
    return 0


def _take_unheld_pen(r, args, issue, session):
    """Take a pen nobody holds, and report. Returns an exit code.

    An unheld pen has no incumbent to protect, so there is nothing for the
    challenge protocol to mediate: it is simply free. Still CAS-guarded
    (`pen_expect=None`), so a peer who grabs it first aborts this take instead of
    being overwritten. Any challenge lingering against the vanished driver is
    cleared with it — it named a holder who no longer exists.
    """
    if not _set_driver(r, issue, args.as_agent, pen_to=args.as_agent,
                       pen_expect=None, clear_challenge=True,
                       expected_session=session,
                       driver_must_be_participant=True):
        sys.stderr.write(f"bus pen take: huddle or pen changed while taking #{issue}; "
                         "not moving the pen\n")
        return 1
    announce(r, args.room, args.as_agent,
             f"took the unheld pen on #{issue}", topic=f"issue-{issue}")
    print(f"{args.as_agent} took the unheld pen on #{issue}")
    return 0


def cmd_pen_take(r, args):
    """Challenge for the pen (dynamic lead). `--reason` is required evidence.
    If the current driver is ABSENT (no presence anywhere), take it over now at
    the last pushed tip — a vanished driver never blocks progress. If the driver
    is PRESENT, this only RECORDS the challenge (never a hostile steal — the reap
    lesson: idle≠dead); the driver must `pen pass` (concede) or `pen deny`."""
    issue = args.issue
    meta = _huddle_meta(r, issue)
    if not meta:
        sys.stderr.write(f"bus pen take: no huddle on #{issue}\n")
        return 1
    session = huddle_meta_holder(meta, issue)
    if args.as_agent not in meta["participants"]:
        sys.stderr.write(f"bus pen take: you must be a huddle participant first "
                         f"(`bus huddle join`)\n")
        return 1
    touch_presence(r, args.room, args.as_agent)  # taking part keeps you live
    driver = r.get(k_pen(issue))
    if driver == args.as_agent:
        print(f"you ({args.as_agent}) already hold the pen on #{issue}")
        return 0
    if not driver:
        # Nobody holds the pen — a driver drained on shutdown, or the key lapsed.
        # There is no incumbent to protect, so the grace window has nothing to
        # protect: an unheld pen is simply free. Without this, an unheld pen still
        # costs a challenger the full PEN_TAKE_GRACE and the huddle can't make a
        # single write until it expires.
        return _take_unheld_pen(r, args, issue, session)
    raw = r.get(k_penchal(issue))
    driver_absent = not _holder_present(r, driver)
    # Operator decision (#94): a driver with NO presence anywhere is treated as
    # gone — take the pen IMMEDIATELY rather than recording a challenge and waiting
    # out PEN_TAKE_GRACE. Pen ops refresh presence, so an actively-driving agent is
    # never absent; this fires only for a drained/vanished driver, and a draining
    # driver's own release must not strand the huddle. The take stays CAS-guarded
    # (pen_expect=driver + expected_session + challenge_expect), so it aborts
    # cleanly if the driver reappears or the huddle changes mid-take. Trade-off:
    # this drops the brief-heartbeat-lapse grace in favour of immediate progress.
    if driver_absent:
        if not _set_driver(r, issue, args.as_agent, pen_to=args.as_agent,
                           pen_expect=driver, clear_challenge=True,
                           expected_session=session,
                           driver_must_be_participant=True,
                           challenge_expect=raw):
            # #106: `pen_expect=driver` can miss because the very drain we are
            # racing has ALREADY released the pen — there is no holder at all now.
            # That is not a refusal: an unheld pen is free, and this take was
            # justified by the driver's absence, which the release only confirms.
            # Without this the take failed on its first try and needed a manual
            # retry, which is exactly the stall #94 removed the grace window to
            # avoid. Re-read once: only a pen still HELD (a returning driver, or a
            # faster peer) is a genuine reason to refuse.
            if r.get(k_pen(issue)) is None:
                return _take_unheld_pen(r, args, issue, session)
            sys.stderr.write(f"bus pen take: huddle or pen changed while taking #{issue}; "
                             "not moving the pen\n")
            return 1
        announce(r, args.room, args.as_agent,
                 f"took the pen on #{issue} (driver {driver} absent)",
                 topic=f"issue-{issue}")
        print(f"{args.as_agent} took the pen on #{issue} (driver {driver} absent)")
        return 0
    # driver PRESENT — record/refresh the challenge (never an instant steal)
    if not _record_pen_challenge(r, issue, args.as_agent, args.reason, session, driver):
        sys.stderr.write(f"bus pen take: huddle or pen changed while challenging #{issue}; "
                         "not recording challenge\n")
        return 1
    announce(r, args.room, args.as_agent,
             f"challenges for the pen on #{issue} (reason: {args.reason}). "
             f"driver {driver} must `pen pass --to {args.as_agent}` or `pen deny`.",
             topic=f"issue-{issue}")
    print(f"{args.as_agent} challenged for the pen on #{issue}; driver {driver} must respond")
    return 0


def cmd_pen_deny(r, args):
    """Current driver rejects an open pen challenge, keeping the pen."""
    issue = args.issue
    if not _require_pen(r, issue, args.as_agent, "deny"):
        return 1
    touch_presence(r, args.room, args.as_agent)
    raw = r.get(k_penchal(issue))
    if not raw:
        sys.stderr.write(f"bus pen deny: no open challenge on #{issue}\n")
        return 1
    chal = json.loads(raw)
    if not _delete_pen_challenge(r, issue, args.as_agent, raw):
        sys.stderr.write(f"bus pen deny: challenge changed while denying #{issue}; "
                         "not deleting it\n")
        return 1
    announce(r, args.room, args.as_agent,
             f"denied {chal['challenger']}'s pen challenge on #{issue} "
             f"(reason: {args.reason}); keeps the pen.", topic=f"issue-{issue}")
    print(f"{args.as_agent} denied the pen challenge on #{issue}")
    return 0


def cmd_pen(r, args):
    return {"status": cmd_pen_status, "checkpoint": cmd_pen_checkpoint,
            "pass": cmd_pen_pass, "take": cmd_pen_take, "deny": cmd_pen_deny}[args.pen_cmd](r, args)


def _shared_tip(issue):
    """Full SHA of the shared branch tip, or None."""
    try:
        main = main_repo_dir()
    except RuntimeError:
        return None
    git(main, "fetch", "origin", huddle_branch(issue), check=False)
    rc, out, _ = git(main, "rev-parse", f"origin/{huddle_branch(issue)}", check=False)
    return out if rc == 0 else None


def _mutate_json(r, key, fn, default):
    """WATCH/MULTI read-modify-write of a JSON value at `key`; retries on a
    concurrent write so a block/signoff isn't lost to a lost-update race."""
    with r.pipeline() as pipe:
        while True:
            try:
                pipe.watch(key)
                raw = pipe.get(key)
                new = fn(json.loads(raw) if raw else default)
                pipe.multi()
                pipe.set(key, json.dumps(new))
                pipe.execute()
                return new
            except redis.WatchError:
                continue


def cmd_signoff(r, args):
    """Sign off on the huddle's current shared tip (or --block it). Sign-offs pin
    the tip SHA: any later checkpoint (push) makes them stale, so the done-gate
    can't be gamed by signing good code then pushing a poison commit."""
    issue = args.issue
    meta = _huddle_meta(r, issue)
    if not meta:
        sys.stderr.write(f"bus signoff: no huddle on #{issue}\n")
        return 1
    if args.as_agent not in meta["participants"]:
        sys.stderr.write(f"bus signoff: you must be a huddle participant\n")
        return 1
    touch_presence(r, args.room, args.as_agent)
    if args.block:
        _mutate_json(r, k_block(issue),
                     lambda bl: [b for b in bl if b["agent"] != args.as_agent]
                                + [{"agent": args.as_agent, "reason": args.block}], [])
        announce(r, args.room, args.as_agent, f"BLOCKED #{issue}: {args.block}",
                 topic=f"issue-{issue}")
        print(f"{args.as_agent} blocked #{issue}: {terminal_line(args.block)}")
        return 0
    tip = _shared_tip(issue)
    if not tip:
        sys.stderr.write(f"bus signoff: cannot read the shared branch tip\n")
        return 1
    _mutate_json(r, k_signoff(issue), lambda s: {**s, args.as_agent: tip}, {})
    announce(r, args.room, args.as_agent, f"signed off on #{issue} at {tip[:8]}",
             topic=f"issue-{issue}")
    print(f"{args.as_agent} signed off on #{issue} (tip {tip[:8]})")
    return 0


def cmd_unblock(r, args):
    """Remove your own block from a huddle."""
    issue = args.issue
    removed = {"any": False}

    def drop(bl):
        kept = [b for b in bl if b["agent"] != args.as_agent]
        removed["any"] = len(kept) != len(bl)
        return kept

    _mutate_json(r, k_block(issue), drop, [])
    if not removed["any"]:
        sys.stderr.write(f"bus unblock: you have no block on #{issue}\n")
        return 1
    announce(r, args.room, args.as_agent, f"lifted their block on #{issue}",
             topic=f"issue-{issue}")
    print(f"{args.as_agent} unblocked #{issue}")
    return 0


def donegate(r, issue, meta, closer):
    """(ok, reasons). Done iff (a) the closing agent has signed off at the CURRENT
    shared tip — a floor so a huddle can never close with zero sign-offs — and (b)
    every OTHER present participant has too, and (c) no block is open. Absent
    participants (idle≠dead) don't freeze the gate; an active block always counts."""
    reasons = []
    braw = r.get(k_block(issue))
    for b in (json.loads(braw) if braw else []):
        reasons.append(f"BLOCK by {b['agent']}: {b['reason']}")
    tip = _shared_tip(issue)
    if not tip:
        return False, reasons + ["cannot read the shared branch tip"]
    sraw = r.get(k_signoff(issue))
    signs = json.loads(sraw) if sraw else {}
    if signs.get(closer) != tip:
        reasons.append(f"the closing agent {closer} must sign off at the current tip "
                       f"{tip[:8]} (a huddle can't close with no sign-off)")
    for p in meta["participants"]:
        if p != closer and _holder_present(r, p) and signs.get(p) != tip:
            reasons.append(f"{p} has not signed off at the current tip {tip[:8]}")
    return (len(reasons) == 0), reasons


def cmd_huddle_recover(r, args):
    """Recover a driver's committed-but-unpushed work after a push mismatch or a
    git-ref collision. Re-syncs to the TRUE current remote tip and re-pushes, leased,
    only when our HEAD cleanly fast-forwards it — NEVER resetting away local commits
    and NEVER forcing over a genuine divergence. Idempotent: safe to re-run.

    Only the pen holder may recover — recovery pushes to the shared branch, which the
    single-writer pen invariant reserves to the holder."""
    issue = args.issue
    if not _require_pen(r, issue, args.as_agent, "recover"):
        return 1
    touch_presence(r, args.room, args.as_agent)
    try:
        main = main_repo_dir()
    except RuntimeError as e:
        sys.stderr.write(f"bus huddle recover: {e}\n")
        return 1
    shared = huddle_branch(issue)
    # huddle_worktree freshly fetches origin/<shared> and syncs the worktree without
    # ever discarding committed-but-unpushed work (it skips the reset when HEAD isn't
    # an ancestor of the shared tip).
    path = huddle_worktree(r, main, issue, args.as_agent)
    if not path:
        return 1
    integrated = _synced_tip(path, shared)
    if not integrated:
        sys.stderr.write(f"bus huddle recover: shared branch origin/{shared} missing; "
                         f"cannot recover safely (was the huddle closed?)\n")
        return 1
    _, head, _ = git(path, "rev-parse", "HEAD", check=False)
    if head == integrated:
        print(f"recover #{issue}: already in sync at {head[:8]}; nothing to recover")
        return 0
    rc, head, err = _leased_push(path, shared, integrated)
    if rc != 0:
        sys.stderr.write(f"bus huddle recover: {err}\n")
        return 1
    announce(r, args.room, args.as_agent, f"recovered #{issue} (tip {head[:7]})",
             topic=f"issue-{issue}")
    print(f"{args.as_agent} recovered #{issue} -> {shared} at {head[:8]}")
    return 0


def cmd_huddle(r, args):
    return {"open": cmd_huddle_open, "join": cmd_huddle_join,
            "status": cmd_huddle_status, "close": cmd_huddle_close,
            "recover": cmd_huddle_recover}[args.huddle_cmd](r, args)


# ---- argparse --------------------------------------------------------------

TTL_HELP = "lock TTL seconds (default 8h)"

# agent ids and room names become filename and Redis-key components, so keep
# them to a safe charset (no path separators, no glob/':' key confusion).
_ID_RE = re.compile(r"^[A-Za-z0-9._-]+$")


def ident(value):
    if not _ID_RE.match(value):
        raise argparse.ArgumentTypeError(
            f"'{value}' must match [A-Za-z0-9._-]+ (no slashes/spaces/':')")
    return value


def positive_int(value):
    if not value.isdigit() or int(value) < 1:
        raise argparse.ArgumentTypeError(f"'{value}' must be a positive integer")
    return int(value)


def _as(parser):
    parser.add_argument("--as", dest="as_agent", type=ident, required=True,
                        help="your agent id")


def _topic(parser):
    parser.add_argument("--topic", type=ident, default=None,
                        help="only deliver messages with this exact topic")


def _issue(parser):
    parser.add_argument("--issue", type=positive_int, required=True)


def build_parser():
    p = argparse.ArgumentParser(prog="bus", description="Tiny durable multi-agent message bus (Redis Streams).")
    p.add_argument("--url", default=DEFAULT_URL, help=f"Redis URL (default {DEFAULT_URL})")
    p.add_argument("--room", default=DEFAULT_ROOM, type=ident, help=f"room/topic stream (default {DEFAULT_ROOM})")
    p.add_argument("--json", action="store_true", help="machine-readable output")
    p.add_argument("--version", action="version", version="bus 0.1.0")
    sub = p.add_subparsers(dest="cmd", required=True)

    s = sub.add_parser("send", help="publish a message")
    s.add_argument("--from", dest="frm", type=ident, required=True, help="your agent id")
    s.add_argument("--to", default="all", type=ident, help="recipient agent id or 'all' (default all)")
    # default=None (not "") so argparse doesn't run `ident` on the empty default
    # and reject a plain send with no topic; cmd_send maps None -> "".
    s.add_argument("--topic", type=ident, default=None, help="optional topic slug, e.g. issue-42 (must be filter-safe: [A-Za-z0-9._-]+)")
    s.add_argument("--reply-to", default="", help="message id you're replying to")
    s.add_argument("--kind", default="msg", help="msg|question|answer|system (default msg)")
    s.add_argument("body", nargs="?", help="message text, or '-' / piped stdin")

    p_poll = sub.add_parser("poll", help="read new messages (non-blocking)")
    _as(p_poll); _topic(p_poll)

    w = sub.add_parser("wait", help="block until a message for you arrives")
    _as(w); _topic(w)
    w.add_argument("--timeout", type=float, default=30.0, help="seconds (default 30)")
    w.add_argument("--reply-to", dest="reply_to", type=ident, default=None,
                   help="only wake on a reply to this message id")

    t = sub.add_parser("tail", help="recent messages, no cursor change")
    t.add_argument("-n", type=int, default=20)
    h = sub.add_parser("history", help="full room log")
    h.add_argument("-n", type=int, default=1000)

    ev = sub.add_parser("events", help="recent structured events (JSON observability layer)")
    ev.add_argument("-n", type=int, default=20, help="max events to show (default 20)")
    ev.add_argument("--type", type=ident, default=None,
                    help="only this event type, e.g. donegate_block")

    wt = sub.add_parser("watch", help="live-follow all messages in a room (observer, Ctrl-C to stop)")
    wt.add_argument("-n", type=int, default=10, help="show last N for context before following (default 10)")
    _topic(wt)

    thr = sub.add_parser("thread", help="print the reply_to thread containing a message id")
    thr.add_argument("id", type=ident, help="a message id somewhere in the thread")

    _as(sub.add_parser("inbox", help="peek unread messages for you (directed or questions); cursor untouched"))

    pr = sub.add_parser("prune", help="trim a room to the newest --keep messages (destructive, guarded)")
    pr.add_argument("--keep", type=positive_int, default=5000, help="messages to keep (default 5000)")
    pr.add_argument("--force", action="store_true", help="trim even if it drops unread for lagging agents")
    pr.add_argument("--dry-run", dest="dry_run", action="store_true",
                    help="report what would be trimmed (and who is lagging); write nothing")

    dr = sub.add_parser("drain", help="graceful shutdown: release your pens + presence (claims kept)")
    _as(dr)
    dr.add_argument("--force", action="store_true",
                    help="drop the pen even with committed-but-unpushed work (strands it)")

    rp = sub.add_parser("reap", help="list stale issue locks (holder absent); --release <issue> to free ONE")
    rp.add_argument("--release", type=positive_int, default=None, metavar="ISSUE",
                    help="release exactly one stale lock you've verified is dead (default: list only)")

    sub.add_parser("board", help="table of gh issues + status + lock holder + presence")

    _as(sub.add_parser("join", help="register presence, cursor to now"))
    sub.add_parser("agents", help="list present agents")

    c = sub.add_parser("claim", help="atomically claim a gh issue")
    _as(c); _issue(c)
    c.add_argument("--ttl", type=int, default=28800, help=TTL_HELP)
    c.add_argument("--worktree", action="store_true",
                   help="also create an isolated git worktree for this issue (fail-closed)")
    c.add_argument("--base", type=ident, default="dev",
                   help="base branch for --worktree, freshly fetched (default dev)")

    rl = sub.add_parser("release", help="release a claim you hold")
    _as(rl); _issue(rl)

    rn = sub.add_parser("renew", help="extend the TTL on a claim you hold")
    _as(rn); _issue(rn)
    rn.add_argument("--ttl", type=int, default=28800, help=TTL_HELP)

    st = sub.add_parser("status", help="transition a gh issue status label")
    _as(st); _issue(st)
    st.add_argument("--set", required=True, choices=STATUS_LABELS)
    st.add_argument("--ttl", type=int, default=28800, help=TTL_HELP)

    ws = sub.add_parser("ws", help="per-agent git worktrees for isolated parallel building")
    wsub = ws.add_subparsers(dest="ws_cmd", required=True)
    wc = wsub.add_parser("create", help="create/resume an isolated worktree for an issue you claimed")
    _as(wc); _issue(wc)
    wc.add_argument("--base", type=ident, default="dev", help="base branch, freshly fetched (default dev)")
    wc.add_argument("--type", type=ident, default="feat", help="branch type prefix (default feat)")
    wc.add_argument("--allow-stale", action="store_true", help="proceed even if git fetch fails (RISKY)")
    wc.add_argument("--allow-nested", action="store_true", help="allow a worktree root inside the repo")
    wp = wsub.add_parser("path", help="print the worktree path for an issue")
    _issue(wp)
    wsub.add_parser("list", help="list all agent worktrees (dirty / unpushed / present)")
    wr = wsub.add_parser("remove", help="remove an issue's worktree (guarded: refuses dirty/unpushed)")
    _as(wr); _issue(wr)
    wr.add_argument("--force", action="store_true", help="remove even if dirty/unpushed or not owner")

    hd = sub.add_parser("huddle", help="collaborative co-work on one issue (stage 1: open/join/status/close)")
    hdsub = hd.add_subparsers(dest="huddle_cmd", required=True)
    ho = hdsub.add_parser("open", help="open a huddle: lock the issue, create the shared branch, status:claimed")
    _as(ho); _issue(ho)
    ho.add_argument("--base", type=ident, default="dev", help="base branch for the shared huddle branch (default dev)")
    ho.add_argument("--ttl", type=int, default=28800, help=TTL_HELP)
    ho.add_argument("--allow-stale", action="store_true", help="proceed even if git fetch fails (RISKY)")
    hj = hdsub.add_parser("join", help="join an open huddle as a participant")
    _as(hj); _issue(hj)
    hs = hdsub.add_parser("status", help="print huddle opener/driver/participants/branch/status")
    _issue(hs)
    hc = hdsub.add_parser("close", help="close the huddle (done-gate: all present signed off, no blocks)")
    _as(hc); _issue(hc)
    hc.add_argument("--force", action="store_true", help="close even if the done-gate isn't met")
    hr = hdsub.add_parser("recover", help="re-push a driver's unpushed work after a push "
                                          "mismatch / git-ref collision (never resets or forces)")
    _as(hr); _issue(hr)

    pn = sub.add_parser("pen", help="huddle write pen: who commits to the shared branch")
    pnsub = pn.add_subparsers(dest="pen_cmd", required=True)
    ps = pnsub.add_parser("status", help="print the current pen holder + shared branch tip")
    _issue(ps)
    pc = pnsub.add_parser("checkpoint", help="pen holder: commit + push your WIP to the shared branch")
    _as(pc); _issue(pc)
    pp = pnsub.add_parser("pass", help="hand the pen to another participant (commit+push first)")
    _as(pp); _issue(pp)
    pp.add_argument("--to", type=ident, required=True, help="the participant to hand the pen to")
    pt = pnsub.add_parser("take", help="challenge for the pen (dynamic lead); force-takes from an absent driver")
    _as(pt); _issue(pt)
    pt.add_argument("--reason", required=True, help="evidence for taking over (failing test, better patch, plan)")
    pd = pnsub.add_parser("deny", help="current driver: reject an open pen challenge")
    _as(pd); _issue(pd)
    pd.add_argument("--reason", required=True, help="why you keep the pen")

    sg = sub.add_parser("signoff", help="sign off on the huddle's current tip (or --block it)")
    _as(sg); _issue(sg)
    sg.add_argument("--block", default=None, help="hard-block the huddle with a reason instead of signing off")
    ub = sub.add_parser("unblock", help="lift your own block on a huddle")
    _as(ub); _issue(ub)

    sub.add_parser("init", help="create status:* labels in BUS_GH_REPO")
    sub.add_parser("doctor", help="check redis + gh")
    return p


# command -> handler. Membership here also means "this command needs Redis".
DISPATCH = {
    "send": cmd_send, "poll": cmd_poll, "wait": cmd_wait,
    "tail": cmd_tail, "history": cmd_history, "events": cmd_events,
    "watch": cmd_watch, "join": cmd_join,
    "agents": cmd_agents, "claim": cmd_claim, "release": cmd_release,
    "renew": cmd_renew, "status": cmd_status,
    "thread": cmd_thread, "inbox": cmd_inbox, "prune": cmd_prune,
    "reap": cmd_reap, "drain": cmd_drain, "board": cmd_board, "ws": cmd_ws,
    "huddle": cmd_huddle, "pen": cmd_pen,
    "signoff": cmd_signoff, "unblock": cmd_unblock,
}


def main(argv=None):
    args = build_parser().parse_args(argv)
    if args.cmd == "doctor":
        return cmd_doctor(args.url)
    if args.cmd == "init":
        return cmd_init(args)
    try:
        r = connect(args.url)
    except Exception as e:  # noqa: BLE001
        sys.stderr.write(f"bus: cannot reach Redis at {args.url}: {e}\n")
        sys.stderr.write("  run `bus doctor` or start Redis: ./scripts/start-redis.sh\n")
        return RC_REDIS_DOWN
    return DISPATCH[args.cmd](r, args)


if __name__ == "__main__":
    sys.exit(main())
